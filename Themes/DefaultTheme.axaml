<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Styles.Resources>
    <!-- ── Semantic surface tokens ──────────────────────────────── -->
    <SolidColorBrush x:Key="ThemeBackgroundBrush">#1C1C1C</SolidColorBrush>
    <SolidColorBrush x:Key="ThemeSurfaceBrush">#2B2B2B</SolidColorBrush>
    <SolidColorBrush x:Key="ThemeSurfaceVariantBrush">#3A3A3A</SolidColorBrush>
    <SolidColorBrush x:Key="ThemeSurfaceHighBrush">#242424</SolidColorBrush>
    <SolidColorBrush x:Key="ThemeAccentBrush">#0078D4</SolidColorBrush>
    <SolidColorBrush x:Key="ThemeAccentForegroundBrush">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ThemeBorderBrush">#555555</SolidColorBrush>
    <SolidColorBrush x:Key="ThemeTextPrimaryBrush">#FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ThemeTextSecondaryBrush">#AAAAAA</SolidColorBrush>
    <SolidColorBrush x:Key="ThemeInputBrush">#272727</SolidColorBrush>
    <CornerRadius x:Key="ThemeControlCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="ThemePanelCornerRadius">6</CornerRadius>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource ThemeBackgroundBrush}" />
  </Style>

  <Style Selector="TabControl">
    <Setter Property="Background" Value="{DynamicResource ThemeBackgroundBrush}" />
  </Style>

</Styles>
