<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Library.ViewModels"
        xmlns:svc="using:Library.Services"
        x:Class="Library.Views.AddEditCardWindow"
        x:DataType="vm:AddEditCardViewModel"
        Title="{Binding Title}"
        Width="640" Height="720" MinWidth="480" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

  <Grid>
    <Grid ColumnDefinitions="*,5,240" Margin="16">

      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="8" Margin="0,0,12,0">
        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />

        <!-- Scryfall search -->
        <Border Background="{DynamicResource ThemeSurfaceBrush}"
                CornerRadius="6" Padding="10" Margin="0,0,0,8">
          <StackPanel Spacing="6">
            <TextBlock Text="Search Scryfall" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
              <TextBox Grid.Column="0" Text="{Binding SearchQuery}" Watermark="Card name..." />
              <Button Grid.Column="1" Content="Search" Command="{Binding SearchScryfallCommand}"
                      IsEnabled="{Binding !IsSearching}" />
            </Grid>
            <ProgressBar IsVisible="{Binding IsSearching}" IsIndeterminate="True" />
            <ListBox ItemsSource="{Binding ScryfallResults}" MaxHeight="150"
                     IsVisible="{Binding ScryfallResults.Count}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="svc:ScryfallCardData">
                  <Button HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left"
                          Background="Transparent"
                          Padding="4,2"
                          Command="{Binding $parent[Window].((vm:AddEditCardViewModel)DataContext).SelectScryfallCardCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding Name}" />
                      <TextBlock Text="{Binding SetCode}" Opacity="0.6" FontSize="11" />
                      <TextBlock Text="{Binding CollectorNumber}" Opacity="0.6" FontSize="11" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>

        <!-- Printing picker — visible once printings are loaded -->
        <Border Background="{DynamicResource ThemeSurfaceBrush}"
                CornerRadius="6" Padding="10" Margin="0,0,0,8"
                IsVisible="{Binding PrintingOptions.Count}">
          <StackPanel Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Printings" FontWeight="SemiBold" VerticalAlignment="Center" />
              <ProgressBar IsVisible="{Binding IsLoadingPrintings}" IsIndeterminate="True"
                           Width="60" Height="6" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Click a printing to switch set / collector number."
                       FontSize="11" Opacity="0.65" />
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          MaxHeight="110">
              <ItemsControl ItemsSource="{Binding PrintingOptions}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="4" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="svc:ScryfallCardData">
                    <Button Padding="6,4" Background="Transparent"
                            Command="{Binding $parent[Window].((vm:AddEditCardViewModel)DataContext).SelectPrintingCommand}"
                            CommandParameter="{Binding}">
                      <StackPanel Spacing="2" Width="52">
                        <TextBlock Text="{Binding SetCode}" FontSize="9" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding CollectorNumber}" FontSize="8" HorizontalAlignment="Center"
                                   Opacity="0.65" />
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>
        </Border>

        <!-- Card fields -->
        <Label Content="Name *" />
        <TextBox Text="{Binding Name}" Watermark="Card name" />

        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
          <StackPanel Grid.Column="0" Spacing="4">
            <Label Content="Set Code" />
            <TextBox Text="{Binding SetCode}" Watermark="e.g. MH3" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4">
            <Label Content="Collector #" />
            <TextBox Text="{Binding CollectorNumber}" Watermark="e.g. 123" />
          </StackPanel>
        </Grid>

        <Label Content="Set Name" />
        <TextBox Text="{Binding SetName}" Watermark="Full set name" />

        <Label Content="Scryfall ID" />
        <TextBox Text="{Binding ScryfallId}" Watermark="UUID from Scryfall" />

        <Label Content="ManaBox ID" />
        <TextBox Text="{Binding ManaBoxId, StringFormat=\{0\}}" Watermark="Numeric ID" />

        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
          <StackPanel Grid.Column="0" Spacing="4">
            <Label Content="Rarity" />
            <TextBox Text="{Binding Rarity}" Watermark="common/uncommon/rare/mythic" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4">
            <Label Content="Quantity" />
            <NumericUpDown Value="{Binding Quantity}" Minimum="1" />
          </StackPanel>
        </Grid>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
          <StackPanel Grid.Column="0" Spacing="4">
            <Label Content="Condition" />
            <ComboBox ItemsSource="{Binding Conditions}" SelectedItem="{Binding Condition}" HorizontalAlignment="Stretch" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4">
            <Label Content="Language" />
            <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding Language}" HorizontalAlignment="Stretch" />
          </StackPanel>
        </Grid>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
          <StackPanel Grid.Column="0" Spacing="4">
            <Label Content="Purchase Price" />
            <NumericUpDown Value="{Binding PurchasePrice}" Minimum="0" FormatString="F2" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4">
            <Label Content="Currency" />
            <ComboBox ItemsSource="{Binding Currencies}" SelectedItem="{Binding PurchasePriceCurrency}" HorizontalAlignment="Stretch" />
          </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
          <CheckBox IsChecked="{Binding Foil}" Content="Foil" />
          <CheckBox IsChecked="{Binding Misprint}" Content="Misprint" />
          <CheckBox IsChecked="{Binding Altered}" Content="Altered" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,8">
          <Button Content="Save" Command="{Binding SaveCommand}" Classes="accent" Width="100" />
          <Button Content="Cancel" Command="{Binding CancelCommand}" Width="100" />
        </StackPanel>
      </StackPanel>
      </ScrollViewer>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"
                    Background="Transparent" Cursor="SizeWestEast" />

      <!-- Preview image -->
      <DockPanel Grid.Column="2" Margin="0,44,0,0" LastChildFill="True">
        <TextBlock DockPanel.Dock="Top" Text="Preview" FontWeight="SemiBold" Margin="0,0,0,8" />
        <Border CornerRadius="6" ClipToBounds="True" MinWidth="80"
                Background="{DynamicResource ThemeSurfaceVariantBrush}">
          <Panel>
            <TextBlock Text="No preview" HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding PreviewImage, Converter={x:Static ObjectConverters.IsNull}}" />
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoadingPreview}"
                         VerticalAlignment="Bottom" Margin="8" />
            <Image Source="{Binding PreviewImage}" Stretch="Uniform"
                   IsVisible="{Binding PreviewImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
          </Panel>
        </Border>
      </DockPanel>

    </Grid>
  </Grid>
</Window>
