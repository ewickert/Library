<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Library.Views"
        x:Class="Library.Views.AlternatePrintingsWindow"
        Title="Alternate Printings"
        Width="780" Height="560"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="12">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,10" Spacing="4">
      <TextBlock x:Name="CardNameHeader" FontSize="16" FontWeight="SemiBold" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Width="100" Height="6"
                     VerticalAlignment="Center" IsVisible="True" />
        <TextBlock x:Name="PrintingCountLabel" Opacity="0.6" FontSize="12" VerticalAlignment="Center" />
        <Button Content="−" FontSize="14" Padding="6,2"
                ToolTip.Tip="Zoom out  (Ctrl + Scroll)" Click="OnZoomOutClick" />
        <TextBlock x:Name="ZoomLabel" Text="100%" FontSize="12" VerticalAlignment="Center"
                   Width="40" TextAlignment="Center" Opacity="0.7" />
        <Button Content="+" FontSize="14" Padding="6,2"
                ToolTip.Tip="Zoom in  (Ctrl + Scroll)"  Click="OnZoomInClick" />
      </StackPanel>
    </StackPanel>

    <!-- Gallery -->
    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                  x:Name="GalleryScroller">
      <ItemsControl x:Name="GalleryPanel">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="local:AlternatePrintingTile">
            <Border Width="{Binding TileWidth}" Height="{Binding TileHeight}"
                    Margin="6" CornerRadius="8"
                    ClipToBounds="True"
                    Background="{DynamicResource ThemeSurfaceVariantBrush}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="2">
              <Grid RowDefinitions="*,Auto">

                <!-- Card image -->
                <Panel Grid.Row="0">
                  <ProgressBar IsIndeterminate="True" Width="40" Height="4"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding IsLoadingImage}" />
                  <Image Source="{Binding Image}" Stretch="UniformToFill" />
                </Panel>

                <!-- Set info + action buttons -->
                <Border Grid.Row="1" Background="#CC000000" Padding="6,4">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding SetName}" FontSize="10" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" Foreground="White" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <Border Background="{Binding RarityColor}" CornerRadius="2"
                              Padding="3,1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding RarityLabel}" FontSize="9" FontWeight="Bold"
                                   Foreground="Black" />
                      </Border>
                      <TextBlock Text="{Binding CollectorLabel}" FontSize="9" Opacity="0.7"
                                 Foreground="White" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                      <Button Content="+ List"
                              Command="{Binding AddToShoppingListCommand}"
                              FontSize="9" Padding="4,2"
                              ToolTip.Tip="Add to global shopping list" />
                      <Button Content="+ Deck"
                              Command="{Binding AddToDeckWishlistCommand}"
                              FontSize="9" Padding="4,2"
                              IsVisible="{Binding HasDeckContext}"
                              ToolTip.Tip="{Binding DeckWishlistTooltip}" />
                    </StackPanel>
                  </StackPanel>
                </Border>

              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Load more -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                HorizontalAlignment="Center" Margin="0,6,0,0"
                x:Name="LoadMorePanel" IsVisible="False">
      <Button x:Name="LoadMoreBtn" Content="Load more" Click="OnLoadMoreClick" Padding="16,6" />
      <ProgressBar x:Name="LoadMoreBar" IsIndeterminate="True" Width="80" Height="6"
                   VerticalAlignment="Center" IsVisible="False" />
    </StackPanel>

    <!-- Footer -->
    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
      <Border Grid.Column="0" x:Name="StatusBanner"
              Background="#1E3A2F" CornerRadius="6" Padding="10,5"
              IsVisible="False">
        <TextBlock x:Name="StatusTextBlock" FontSize="12" Foreground="#7DCFAA"
                   VerticalAlignment="Center" />
      </Border>
      <Button Grid.Column="1" Content="Close" Click="OnCloseClick"
              Padding="16,6" Margin="8,0,0,0" />
    </Grid>

  </Grid>
</Window>
