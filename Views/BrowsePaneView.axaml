<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Library.ViewModels"
             xmlns:mtg="using:MtgJson.Models"
             xmlns:controls="using:Library.Views.Controls"
             xmlns:views="using:Library.Views"
             x:Class="Library.Views.BrowsePaneView"
             x:DataType="vm:BrowsePaneViewModel">

  <Grid RowDefinitions="Auto,*">

    <!-- ── Header ────────────────────────────────────────────────────────── -->
    <Border Grid.Row="0" Padding="8,8,8,0">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">

        <!-- Tab buttons -->
        <Button Grid.Column="0" Content="Scryfall" Padding="10,4"
                Classes.active="{Binding IsScryfall}"
                Command="{Binding SelectScryfallCommand}">
          <Button.Styles>
            <Style Selector="Button.active"> <Setter Property="FontWeight" Value="SemiBold" /> </Style>
            <Style Selector="Button:not(.active)"> <Setter Property="Opacity" Value="0.55" /> </Style>
          </Button.Styles>
        </Button>
        <Button Grid.Column="1" Content="Decks" Padding="10,4" Margin="2,0,0,0"
                Classes.active="{Binding IsDecks}"
                Command="{Binding SelectDecksCommand}">
          <Button.Styles>
            <Style Selector="Button.active"> <Setter Property="FontWeight" Value="SemiBold" /> </Style>
            <Style Selector="Button:not(.active)"> <Setter Property="Opacity" Value="0.55" /> </Style>
          </Button.Styles>
        </Button>

        <!-- Spacer -->
        <Panel Grid.Column="2" />

        <!-- Grid/list toggle (Scryfall tab only) -->
        <Button Grid.Column="3"
                Command="{Binding ToggleViewCommand}"
                Padding="6,4" ToolTip.Tip="Toggle grid / list"
                IsVisible="{Binding IsScryfall}">
          <Panel>
            <TextBlock Text="⊞" IsVisible="{Binding !IsGridView}" FontSize="13" />
            <TextBlock Text="☰" IsVisible="{Binding IsGridView}" FontSize="13" />
          </Panel>
        </Button>

        <!-- Loading indicator -->
        <ProgressBar Grid.Column="4"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsSearching}"
                     Width="40" Height="6"
                     VerticalAlignment="Center" Margin="4,0" />

        <!-- Pop-out button -->
        <Button Grid.Column="5" x:Name="PopOutButton"
                Content="⤢" ToolTip.Tip="Pop out into floating window"
                Padding="6,4" Click="OnPopOutClick" />

      </Grid>
    </Border>

    <!-- ── Content ───────────────────────────────────────────────────────── -->
    <Panel Grid.Row="1">

      <!-- ── Scryfall tab ─────────────────────────────────────────────── -->
      <Grid RowDefinitions="Auto,*,Auto"
            IsVisible="{Binding IsScryfall}">

        <!-- Search box -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="6" Margin="8,6,8,4">
          <TextBox Grid.Column="0"
                   Text="{Binding SearchText}"
                   Watermark="Search Scryfall…"
                   FontSize="12" />
          <Button Grid.Column="1"
                  Content="🔍"
                  Command="{Binding SearchCommand}"
                  Padding="8,4" FontSize="12"
                  ToolTip.Tip="Search" />
        </Grid>

        <!-- Results -->
        <Panel Grid.Row="1">

          <!-- List view -->
          <ScrollViewer x:Name="ScryfallList"
                        VerticalScrollBarVisibility="Auto"
                        IsVisible="{Binding !IsGridView}">
            <StackPanel>
              <TextBlock Text="Type to search Scryfall…"
                         IsVisible="{Binding Results.Count, Converter={x:Static ObjectConverters.IsNull}}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Opacity="0.5" Margin="8,24" FontSize="12" />
              <ItemsControl x:Name="ScryfallListItems" ItemsSource="{Binding Results}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ScryfallResultViewModel">
                    <Border x:Name="ScryfallListItem"
                            Padding="8,6" BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            Cursor="Grab">
                      <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel Grid.Column="0" Spacing="1">
                          <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock FontSize="10" Opacity="0.7" TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding SetCode}" /><Run Text=" · " /><Run Text="{Binding TypeLine}" />
                          </TextBlock>
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <controls:ManaSymbolsControl ManaCost="{Binding ManaCost}"
                                IsVisible="{Binding ManaCost, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            <TextBlock Text="{Binding Rarity}" FontSize="10" Opacity="0.7" VerticalAlignment="Center" />
                          </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ToggleShoppingListCommand}"
                                Padding="5,2" FontSize="11" VerticalAlignment="Center" Margin="3,0,0,0"
                                ToolTip.Tip="Toggle shopping list">
                          <Panel>
                            <TextBlock Text="♥" IsVisible="{Binding !IsOnShoppingList}" />
                            <TextBlock Text="✓" IsVisible="{Binding IsOnShoppingList}" Foreground="LightGreen" />
                          </Panel>
                        </Button>
                        <Button Grid.Column="2"
                                Command="{Binding AddToCollectionCommand}"
                                Padding="6,2" FontSize="13" FontWeight="Bold"
                                VerticalAlignment="Center" Margin="3,0,0,0"
                                ToolTip.Tip="Add to collection"
                                IsEnabled="{Binding !IsInCollection}">
                          <Panel>
                            <TextBlock Text="+" IsVisible="{Binding !IsInCollection}" />
                            <TextBlock Text="✓" IsVisible="{Binding IsInCollection}" Foreground="LightGreen" FontSize="11" />
                          </Panel>
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>

          <!-- Grid view -->
          <ScrollViewer x:Name="ScryfallGrid"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        IsVisible="{Binding IsGridView}">
            <ItemsControl x:Name="ScryfallGridItems" ItemsSource="{Binding Results}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ScryfallResultViewModel">
                  <Border Width="120" Height="168" CornerRadius="6" ClipToBounds="True"
                          Margin="4" Cursor="Grab"
                          ToolTip.ShowDelay="300"
                          Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                    <ToolTip.Tip>
                      <Border Background="#1A1A2A" CornerRadius="8" Padding="6">
                        <Panel>
                          <Image Source="{Binding Image}" MaxWidth="280" MaxHeight="392" Stretch="Uniform"
                                 IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                          <StackPanel Spacing="4" Margin="4"
                                      IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}">
                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" FontWeight="Bold"
                                       TextWrapping="Wrap" MaxWidth="268" />
                            <TextBlock Text="{Binding TypeLine}" Foreground="#CCCCCC" FontSize="11"
                                       TextWrapping="Wrap" MaxWidth="268" />
                            <controls:ManaSymbolsControl ManaCost="{Binding ManaCost}" />
                          </StackPanel>
                        </Panel>
                      </Border>
                    </ToolTip.Tip>
                    <Panel>
                      <Image Source="{Binding Image}" Stretch="UniformToFill"
                             IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                  IsVisible="{Binding IsLoading}" Spacing="4">
                        <ProgressBar IsIndeterminate="True" Width="60" />
                        <TextBlock Text="{Binding Name}" FontSize="9" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   Opacity="0.6" MaxWidth="100" />
                      </StackPanel>
                      <Panel IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}">
                        <Panel IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}">
                          <StackPanel Spacing="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🃏" FontSize="22" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Name}" FontSize="9" TextWrapping="Wrap"
                                       MaxWidth="100" HorizontalAlignment="Center" TextAlignment="Center" />
                          </StackPanel>
                        </Panel>
                      </Panel>
                      <!-- Add button -->
                      <Button Command="{Binding AddToCollectionCommand}"
                              HorizontalAlignment="Right" VerticalAlignment="Top"
                              Margin="3" Padding="5,2" FontSize="12" FontWeight="Bold"
                              CornerRadius="4" ToolTip.Tip="Add to collection"
                              IsEnabled="{Binding !IsInCollection}">
                        <Button.Styles>
                          <Style Selector="Button">
                            <Setter Property="Background" Value="#CC1D6B2F" />
                            <Setter Property="Foreground" Value="White" />
                          </Style>
                          <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#EE2B8C42" />
                          </Style>
                        </Button.Styles>
                        <Panel>
                          <TextBlock Text="+" IsVisible="{Binding !IsInCollection}" />
                          <TextBlock Text="✓" IsVisible="{Binding IsInCollection}" Foreground="#B8FFB8" />
                        </Panel>
                      </Button>
                      <!-- Caption -->
                      <Border Background="#AA000000" CornerRadius="0,0,6,6"
                              VerticalAlignment="Bottom" Padding="4,2">
                        <TextBlock Text="{Binding Name}" FontSize="9" Foreground="White"
                                   TextTrimming="CharacterEllipsis" />
                      </Border>
                    </Panel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

        </Panel>

        <!-- Load More -->
        <Button Grid.Row="2"
                Content="Load More"
                Command="{Binding LoadMoreCommand}"
                IsVisible="{Binding HasMore}"
                HorizontalAlignment="Stretch"
                Margin="8,4" Padding="6,4" FontSize="11" />

      </Grid>

      <!-- ── Decks tab ────────────────────────────────────────────────── -->
      <Panel IsVisible="{Binding IsDecks}">
        <views:MtgJsonPaneView DataContext="{Binding Decks}" />
      </Panel>

    </Panel>

  </Grid>
</UserControl>
