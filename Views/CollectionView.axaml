<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Library.ViewModels"
             xmlns:models="using:Library.Models"
             xmlns:controls="using:Library.Views.Controls"
             xmlns:views="using:Library.Views"
             x:Class="Library.Views.CollectionView"
             x:DataType="vm:CollectionViewModel">

  <UserControl.Styles>
    <Style Selector="Button.toolbarActive">
      <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
  </UserControl.Styles>

  <Grid x:Name="RootGrid" RowDefinitions="Auto,*,Auto">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" MinWidth="320" />
      <ColumnDefinition Width="0.34*" MinWidth="220" MaxWidth="360" />
    </Grid.ColumnDefinitions>

    <!-- Toolbar + status strip -->
    <StackPanel Grid.Row="0" Grid.Column="0" Margin="8,8,8,4">

      <!-- Main toolbar -->
      <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">

        <!-- Search -->
        <TextBox Text="{Binding SearchText}" Watermark="Search cards…" Width="200" />
        <Button Content="?" ToolTip.Tip="Search syntax help" Click="OnSearchHelpClick"
                Padding="6,4" FontWeight="Bold" />

        <!-- Set filter -->
        <ComboBox ItemsSource="{Binding AvailableSets}" SelectedItem="{Binding SelectedSetFilter}"
                  Width="160" MaxDropDownHeight="300">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="vm:SetItem">
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <controls:SetIconControl SetCode="{Binding Code}" />
                <TextBlock Text="{Binding Display}" VerticalAlignment="Center" />
              </StackPanel>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- Add card -->
        <Button Content="+ Add" Click="OnAddCardClick" ToolTip.Tip="Add a card to the collection"
                Padding="8,4" />

        <!-- ─── divider ─── -->
        <Rectangle Width="1" Height="18" Margin="4,0" VerticalAlignment="Center"
                   Fill="{DynamicResource SystemControlForegroundBaseLowBrush}" Opacity="0.35" />

        <!-- View mode toggle -->
        <Button Command="{Binding ToggleViewCommand}" Padding="7,4"
                ToolTip.Tip="Toggle list / grid view">
          <StackPanel Orientation="Horizontal" Spacing="3">
            <TextBlock Text="☰" IsVisible="{Binding !IsGridView}" FontSize="12" />
            <TextBlock Text="⊞" IsVisible="{Binding IsGridView}" FontSize="12" />
          </StackPanel>
        </Button>

        <!-- Browse pane toggle -->
        <Button Command="{Binding ToggleBrowsePaneCommand}" Padding="7,4"
                ToolTip.Tip="Browse Scryfall / MTGJSON decks"
                Classes.toolbarActive="{Binding IsBrowsePaneOpen}">
          <TextBlock Text="⊡" FontSize="12" />
        </Button>


      </StackPanel>

      <!-- Status strip — only visible when backfill or price refresh is running -->
      <StackPanel Orientation="Horizontal" Spacing="16" Margin="2,3,0,0">
        <TextBlock Text="{Binding BackfillStatus}" FontSize="11" Opacity="0.65"
                   IsVisible="{Binding BackfillStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Text="{Binding PriceRefreshStatus}" FontSize="11" Opacity="0.65"
                   IsVisible="{Binding PriceRefreshStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>

    </StackPanel>

    <!-- List / Grid area -->
    <Panel x:Name="CollectionPanel" Grid.Row="1" Grid.Column="0"
           DragDrop.AllowDrop="True">

      <!-- List view -->
      <DataGrid x:Name="CollectionDataGrid"
                ItemsSource="{Binding Cards}"
                SelectedItem="{Binding SelectedCard}"
                IsReadOnly="False"
                AutoGenerateColumns="False"
                GridLinesVisibility="Horizontal"
                CanUserResizeColumns="True"
                IsVisible="{Binding !IsGridView}"
                RowEditEnded="OnCollectionRowEditEnded"
                Margin="8,0,4,8">
        <DataGrid.Styles>
          <Style Selector="DataGridRow">
            <Setter Property="ToolTip.Tip" Value="{Binding}" />
            <Setter Property="ToolTip.ShowDelay" Value="300" />
          </Style>
          <Style Selector="DataGridColumnHeader">
            <Setter Property="ToolTip.Tip" Value="{Binding $self.Content}" />
            <Setter Property="ToolTip.ShowDelay" Value="400" />
          </Style>
        </DataGrid.Styles>
        <DataGrid.DataTemplates>
          <DataTemplate DataType="models:Card">
            <controls:CardImageControl Card="{Binding}" />
          </DataTemplate>
        </DataGrid.DataTemplates>
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True" />
          <DataGridTextColumn Header="Set" Binding="{Binding SetCode}" Width="50" IsReadOnly="True" />
          <DataGridTextColumn Header="#" Binding="{Binding CollectorNumber}" Width="50" IsReadOnly="True" />
          <DataGridTemplateColumn Header="Foil" Width="50" IsReadOnly="True">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding Foil, Mode=OneWay}" IsHitTestVisible="False" HorizontalAlignment="Center" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Rarity" Binding="{Binding Rarity}" Width="70" IsReadOnly="True" />
          <DataGridTextColumn Header="Condition" Binding="{Binding Condition}" Width="70" IsReadOnly="True" />
          <DataGridTextColumn Header="Language" Binding="{Binding Language}" Width="60" IsReadOnly="True" />
          <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="45" IsReadOnly="True" />
          <DataGridTextColumn Header="Paid" Binding="{Binding PurchasePrice, StringFormat=\{0:F2\}}" Width="70" />
          <DataGridTextColumn Header="Currency" Binding="{Binding PurchasePriceCurrency}" Width="60" IsReadOnly="True" />
          <DataGridTemplateColumn Header="Market Price" Width="120" IsReadOnly="True">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="models:Card">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <TextBlock FontSize="12"
                             Text="{Binding CurrentMarketPrice, StringFormat=\${0:F2}}"
                             IsVisible="{Binding CurrentMarketPrice, Converter={x:Static ObjectConverters.IsNotNull}}" />
                  <TextBlock FontSize="11" Opacity="0.65"
                             IsVisible="{Binding CurrentMarketPrice, Converter={x:Static ObjectConverters.IsNull}}"
                             Text="—" />
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="Misprint" Width="65" IsReadOnly="True">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding Misprint, Mode=OneWay}" IsHitTestVisible="False" HorizontalAlignment="Center" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="Altered" Width="60" IsReadOnly="True">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding Altered, Mode=OneWay}" IsHitTestVisible="False" HorizontalAlignment="Center" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Added" Binding="{Binding Added, StringFormat=\{0:yyyy-MM-dd\}}" Width="90" IsReadOnly="True" />
        </DataGrid.Columns>
      </DataGrid>

      <!-- Touch-friendly compact list for narrow screens -->
      <ScrollViewer x:Name="MobileCollectionList" IsVisible="{Binding !IsGridView}"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Margin="8,0,4,8">
        <ItemsControl ItemsSource="{Binding Cards}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:Card">
              <Button Background="Transparent" Padding="0" Margin="0,0,0,8"
                      Command="{Binding $parent[UserControl].((vm:CollectionViewModel)DataContext).SelectCardCommand}"
                      CommandParameter="{Binding}">
                <Border Padding="10" CornerRadius="8"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock FontSize="11" Opacity="0.75" TextTrimming="CharacterEllipsis">
                        <Run Text="{Binding SetCode}" /><Run Text=" #" /><Run Text="{Binding CollectorNumber}" />
                        <Run Text="  •  " /><Run Text="{Binding Condition}" />
                      </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="2">
                      <TextBlock Text="{Binding Quantity, StringFormat=Qty {0}}" FontSize="11" HorizontalAlignment="Right" />
                      <TextBlock Text="{Binding PurchasePrice, StringFormat=\${0:F2}}"
                                 IsVisible="{Binding PurchasePrice, Converter={x:Static ObjectConverters.IsNotNull}}"
                                 FontSize="11" Opacity="0.8" HorizontalAlignment="Right" />
                    </StackPanel>
                  </Grid>
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Grid view -->
      <ScrollViewer x:Name="GridScrollViewer" IsVisible="{Binding IsGridView}"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Margin="8,0,4,8">
        <ItemsControl ItemsSource="{Binding CardSlots}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:CardSlotViewModel">
              <Button Padding="0" Margin="6"
                      Command="{Binding $parent[UserControl].((vm:CollectionViewModel)DataContext).SelectCardCommand}"
                      CommandParameter="{Binding Card}"
                      Background="Transparent">
                <Border Width="{Binding $parent[UserControl].((vm:CollectionViewModel)DataContext).TileWidth}"
                        Height="{Binding $parent[UserControl].((vm:CollectionViewModel)DataContext).TileHeight}"
                        CornerRadius="8" ClipToBounds="True"
                        ToolTip.ShowDelay="200"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                  <ToolTip.Tip>
                    <Border Background="#1A1A2A" CornerRadius="8" Padding="6">
                      <Panel>
                        <Image Source="{Binding Image}" MaxWidth="280" MaxHeight="392" Stretch="Uniform"
                               IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <TextBlock Text="{Binding Card.Name}" Foreground="White" FontSize="13" FontWeight="Bold"
                                   TextWrapping="Wrap" MaxWidth="268" Margin="4"
                                   IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}" />
                      </Panel>
                    </Border>
                  </ToolTip.Tip>
                  <Panel>
                    <Image Source="{Binding Image}" Stretch="UniformToFill"
                           IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsVisible="{Binding IsLoading}" Spacing="6">
                      <ProgressBar IsIndeterminate="True" Width="80" />
                      <TextBlock Text="{Binding Card.Name}" FontSize="10" TextWrapping="Wrap"
                                 HorizontalAlignment="Center" TextAlignment="Center" Opacity="0.6" MaxWidth="140" />
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4"
                                IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}">
                      <Panel IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                          <TextBlock Text="🃏" FontSize="32" HorizontalAlignment="Center" />
                          <TextBlock Text="{Binding Card.Name}" FontSize="10" TextWrapping="Wrap"
                                     MaxWidth="140" HorizontalAlignment="Center" TextAlignment="Center" />
                        </StackPanel>
                      </Panel>
                    </StackPanel>
                    <Border IsVisible="{Binding Card.Foil}"
                            Background="#88FFD700" CornerRadius="4"
                            Padding="4,2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4">
                      <TextBlock Text="✦ Foil" FontSize="9" FontWeight="Bold" Foreground="#805500" />
                    </Border>
                    <Border Background="#AA000000" CornerRadius="0,0,8,8"
                            VerticalAlignment="Bottom" Padding="6,3">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Card.Name}" FontSize="10" Foreground="White"
                                   TextTrimming="CharacterEllipsis" MaxWidth="110" />
                        <TextBlock Text="{Binding Card.Condition}" FontSize="10" Foreground="#AAAAAA" />
                        <!-- Market price + delta -->
                        <TextBlock Text="{Binding CurrentPriceLabel}" FontSize="10" Foreground="#DDDDDD"
                                   IsVisible="{Binding Card.CurrentMarketPrice, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <TextBlock Text="{Binding PriceDeltaLabel}" FontSize="10" Foreground="#44FF88"
                                   IsVisible="{Binding IsPriceUp}" />
                        <TextBlock Text="{Binding PriceDeltaLabel}" FontSize="10" Foreground="#FF5555"
                                   IsVisible="{Binding IsPriceDown}" />
                      </StackPanel>
                    </Border>
                  </Panel>
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

    </Panel>

    <!-- Right panel: switches between card detail and Browse pane -->
    <Panel Grid.Row="0" Grid.Column="1" Grid.RowSpan="3">

    <!-- Browse pane (Scryfall + MTGJSON deck browser) -->
    <Border IsVisible="{Binding IsBrowsePaneOpen}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            CornerRadius="8" Margin="4,8,8,8">
      <views:BrowsePaneView DataContext="{Binding BrowsePane}" />
    </Border>

    <!-- Card detail panel -->
    <Border x:Name="CardDetailPane"
            IsVisible="{Binding !IsBrowsePaneOpen}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            CornerRadius="8" Margin="4,8,8,8" Padding="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="8">
          <TextBlock Text="Card Details" FontWeight="Bold" FontSize="14" />

          <!-- Card image -->
          <Border Width="220" Height="308" CornerRadius="6" ClipToBounds="True"
                  Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
            <Panel>
              <TextBlock Text="No image" HorizontalAlignment="Center" VerticalAlignment="Center"
                         IsVisible="{Binding CardImage, Converter={x:Static ObjectConverters.IsNull}}" />
              <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoadingImage}"
                           VerticalAlignment="Bottom" Margin="8" />
              <Image Source="{Binding CardImage}" Stretch="Uniform"
                     IsVisible="{Binding CardImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
            </Panel>
          </Border>

          <!-- Alternate printings -->
          <StackPanel IsVisible="{Binding SelectedCard, Converter={x:Static ObjectConverters.IsNotNull}}" Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Printings" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
              <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoadingAlternates}"
                           Width="60" Height="8" VerticalAlignment="Center" />
            </StackPanel>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxHeight="130">
              <ItemsControl ItemsSource="{Binding AlternatePrintings}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="4" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:AlternatePrintingViewModel">
                    <Button Padding="0" Background="Transparent"
                            Command="{Binding $parent[UserControl].((vm:CollectionViewModel)DataContext).SelectAlternateCommand}"
                            CommandParameter="{Binding}">
                      <StackPanel Spacing="2" Width="72">
                        <Border Width="72" Height="100" CornerRadius="4" ClipToBounds="True"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                ToolTip.Tip="{Binding Data.SetName}">
                          <Panel>
                            <Image Source="{Binding Image}" Stretch="UniformToFill"
                                   IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}"
                                         VerticalAlignment="Center" Margin="4" />
                          </Panel>
                        </Border>
                        <TextBlock Text="{Binding Data.SetCode}" FontSize="9" HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Data.CollectorNumber}" FontSize="9"
                                   HorizontalAlignment="Center" Opacity="0.6" />
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>

          <StackPanel IsVisible="{Binding SelectedCard, Converter={x:Static ObjectConverters.IsNotNull}}" Spacing="4">
            <TextBlock Text="{Binding SelectedCard.Name}" FontWeight="Bold" TextWrapping="Wrap" />
            <TextBlock Text="{Binding SelectedCard.SetName}" Opacity="0.7" TextWrapping="Wrap" />
            <TextBlock>
              <Run Text="Rarity: " FontWeight="SemiBold" />
              <Run Text="{Binding SelectedCard.Rarity}" />
            </TextBlock>
            <TextBlock>
              <Run Text="Condition: " FontWeight="SemiBold" />
              <Run Text="{Binding SelectedCard.Condition}" />
            </TextBlock>
            <TextBlock>
              <Run Text="Language: " FontWeight="SemiBold" />
              <Run Text="{Binding SelectedCard.Language}" />
            </TextBlock>
            <TextBlock>
              <Run Text="Foil: " FontWeight="SemiBold" />
              <Run Text="{Binding SelectedCard.Foil}" />
            </TextBlock>
            <TextBlock>
              <Run Text="Quantity: " FontWeight="SemiBold" />
              <Run Text="{Binding SelectedCard.Quantity}" />
            </TextBlock>
            <TextBlock IsVisible="{Binding SelectedCard.PurchasePrice, Converter={x:Static ObjectConverters.IsNotNull}}">
              <Run Text="Price: " FontWeight="SemiBold" />
              <Run Text="{Binding SelectedCard.PurchasePrice, StringFormat=\{0:F2\}}" />
              <Run Text=" " />
              <Run Text="{Binding SelectedCard.PurchasePriceCurrency}" />
            </TextBlock>
            <TextBlock IsVisible="{Binding SelectedCard.ManaBoxId, Converter={x:Static ObjectConverters.IsNotNull}}">
              <Run Text="ManaBox ID: " FontWeight="SemiBold" />
              <Run Text="{Binding SelectedCard.ManaBoxId}" />
            </TextBlock>
            <TextBlock IsVisible="{Binding SelectedCard.ScryfallId, Converter={x:Static ObjectConverters.IsNotNull}}">
              <Run Text="Scryfall ID: " FontWeight="SemiBold" />
              <Run Text="{Binding SelectedCard.ScryfallId}" />
            </TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
              <Button Content="Edit" Click="OnEditCardClick" />
              <Button Content="Delete" Command="{Binding DeleteCardCommand}"
                      Background="#CC3300" Foreground="White" />
            </StackPanel>
          </StackPanel>

          <TextBlock Text="Select a card to view details."
                     IsVisible="{Binding SelectedCard, Converter={x:Static ObjectConverters.IsNull}}"
                     Opacity="0.5" />
        </StackPanel>
      </ScrollViewer>
    </Border>

    </Panel>

    <!-- Compact detail panel for phones/tablets when side pane is hidden -->
    <Border x:Name="CompactCardDetailPane" Grid.Row="2" Grid.Column="0"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            CornerRadius="8" Margin="8,4,4,8" Padding="10"
            IsVisible="False">
      <StackPanel Spacing="8">
        <TextBlock Text="Selected Card" FontWeight="SemiBold" FontSize="13"
                   IsVisible="{Binding SelectedCard, Converter={x:Static ObjectConverters.IsNotNull}}" />
        <TextBlock Text="Select a card to view details and actions."
                   Opacity="0.6"
                   IsVisible="{Binding SelectedCard, Converter={x:Static ObjectConverters.IsNull}}" />

        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10"
              IsVisible="{Binding SelectedCard, Converter={x:Static ObjectConverters.IsNotNull}}">
          <Border Grid.Column="0" Width="80" Height="112" CornerRadius="4" ClipToBounds="True"
                  Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
            <Panel>
              <Image Source="{Binding CardImage}" Stretch="Uniform"
                     IsVisible="{Binding CardImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
              <TextBlock Text="No image" HorizontalAlignment="Center" VerticalAlignment="Center"
                         FontSize="10" Opacity="0.6"
                         IsVisible="{Binding CardImage, Converter={x:Static ObjectConverters.IsNull}}" />
            </Panel>
          </Border>

          <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
            <TextBlock Text="{Binding SelectedCard.Name}" FontWeight="Bold" TextWrapping="Wrap" />
            <TextBlock Text="{Binding SelectedCard.SetName}" Opacity="0.75" TextWrapping="Wrap" />
            <TextBlock FontSize="12" Opacity="0.85">
              <Run Text="Qty " />
              <Run Text="{Binding SelectedCard.Quantity}" />
              <Run Text=" • " />
              <Run Text="{Binding SelectedCard.Condition}" />
            </TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
              <Button Content="Edit" Click="OnEditCardClick" />
              <Button Content="Delete" Command="{Binding DeleteCardCommand}"
                      Background="#CC3300" Foreground="White" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
