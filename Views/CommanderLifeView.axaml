<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Library.ViewModels"
             xmlns:views="using:Library.Views"
             x:Class="Library.Views.CommanderLifeView"
             x:DataType="vm:CommanderLifeViewModel">

  <Grid>
    <DockPanel Margin="0">
      <Border x:Name="TopControlsBorder"
              DockPanel.Dock="Top"
              HorizontalAlignment="Center"
              CornerRadius="12"
              Background="#E00C131D"
              BorderBrush="#663AAEFF"
              BorderThickness="1"
              Padding="8,6"
              Margin="8,8,8,2"
              BoxShadow="0 8 22 0 #28000000, 0 0 0 1 #223AAEFF"
              MaxWidth="440">
        <StackPanel HorizontalAlignment="Center" Spacing="4">
                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8" HorizontalAlignment="Center">
                  <Button x:Name="CenterRollButton"
                    Grid.Column="0"
                    Width="44"
                    Height="44"
                    CornerRadius="22"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#0F2B45"
                    Foreground="White"
                    BorderBrush="#80A7E6FF"
                    BorderThickness="1.5"
                    Click="OnCenterRollButtonClick">
                    <Path Data="M15,2 L27,9 L27,23 L15,30 L3,23 L3,9 Z M15,2 L9,9 L21,9 Z M3,9 L15,16 L27,9 M3,23 L15,16 L27,23 M9,23 L21,23 L15,30 Z"
                    Width="22"
                    Height="22"
                    Stretch="Uniform"
                    Stroke="White"
                    StrokeThickness="1.45"
                    Fill="#33FFFFFF" />
                  </Button>

                  <Button Grid.Column="1"
                    Content="New Game"
                    MinWidth="92"
                    Height="34"
                    CornerRadius="10"
                    Padding="14,0"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#15283D"
                    Foreground="#EAF3FF"
                    BorderBrush="#805EC4FF"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Command="{Binding ResetAllCommand}" />
                </Grid>
        </StackPanel>
      </Border>

      <Grid x:Name="PlayerRegionsHost" RowSpacing="8" ColumnSpacing="8" Margin="8" />
    </DockPanel>

    <Border IsVisible="{Binding IsAwaitingRollAcknowledge}"
            Background="Transparent"
            PointerPressed="OnAcknowledgeOverlayPointerPressed" />
  </Grid>
</UserControl>
