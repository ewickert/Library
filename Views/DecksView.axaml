<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Library.ViewModels"
             xmlns:models="using:Library.Models"
             xmlns:controls="using:Library.Views.Controls"
             xmlns:converters="using:Library.Views"
             xmlns:views="using:Library.Views"
             x:Class="Library.Views.DecksView"
             x:DataType="vm:DecksViewModel">

  <UserControl.Resources>
    <converters:IntGreaterThanOneConverter x:Key="IntGreaterThanOneConverter" />
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- Active state for toolbar icon buttons -->
    <Style Selector="Button.toolbarActive">
      <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Color identity toggle buttons -->
    <Style Selector="ToggleButton.colorBtn">
      <Setter Property="Width" Value="28"/>
      <Setter Property="Height" Value="28"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Opacity" Value="0.4"/>
    </Style>
    <Style Selector="ToggleButton.colorBtn:checked">
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="ToggleButton.colorBtn.W">
      <Setter Property="Background" Value="#EDE0A0"/>
      <Setter Property="Foreground" Value="#5A4A10"/>
    </Style>
    <Style Selector="ToggleButton.colorBtn.U">
      <Setter Property="Background" Value="#1060B0"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton.colorBtn.B">
      <Setter Property="Background" Value="#201825"/>
      <Setter Property="Foreground" Value="#DDDDDD"/>
    </Style>
    <Style Selector="ToggleButton.colorBtn.R">
      <Setter Property="Background" Value="#C82020"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton.colorBtn.G">
      <Setter Property="Background" Value="#1A7A30"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton.colorBtn.C">
      <Setter Property="Background" Value="#A09070"/>
      <Setter Property="Foreground" Value="#1A1510"/>
    </Style>
  </UserControl.Styles>

  <!--
    Layout: [Sidebar] | [Deck Content *] | [Collection] | [Scryfall] | [Stats]
  -->
  <Panel>
  <Grid x:Name="RootGrid">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="0.24*" MinWidth="140" MaxWidth="260" />
      <ColumnDefinition Width="*" MinWidth="200" />
      <ColumnDefinition Width="5" />
      <ColumnDefinition Width="0.34*" MinWidth="180" MaxWidth="340" />
      <ColumnDefinition Width="0" />
      <ColumnDefinition Width="0" MinWidth="0" />
      <ColumnDefinition Width="0" />
      <ColumnDefinition Width="0" MinWidth="0" />
      <ColumnDefinition Width="0" />
      <ColumnDefinition Width="0" MinWidth="0" />
    </Grid.ColumnDefinitions>

    <!-- ══════════════════════════════════════════════════════════
         Col 0: Deck list sidebar
         ══════════════════════════════════════════════════════════ -->
    <DockPanel Grid.Column="0" Margin="8,8,4,8">
      <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,8">
        <TextBlock Text="Decks" FontWeight="Bold" FontSize="14" />
        <Button Content="+ New Deck" Command="{Binding StartCreateDeckCommand}" HorizontalAlignment="Stretch" />

        <!-- New deck form -->
        <Border IsVisible="{Binding IsCreatingDeck}"
                Background="{DynamicResource ThemeSurfaceBrush}"
                CornerRadius="6" Padding="8">
          <StackPanel Spacing="6">
            <TextBox Text="{Binding NewDeckName}" Watermark="Deck name *" />
            <TextBox Text="{Binding NewDeckFormat}" Watermark="Format (Commander, Modern…)" />
            <TextBox Text="{Binding NewDeckDescription}" Watermark="Description" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Create" Command="{Binding ConfirmCreateDeckCommand}" Classes="accent" />
              <Button Content="Cancel" Command="{Binding CancelCreateDeckCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>

      <ListBox ItemsSource="{Binding Decks}" SelectedItem="{Binding SelectedDeck}">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="models:Deck">
            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
              <controls:ArtCropControl Grid.Column="0" ScryfallId="{Binding CommanderScryfallId}"
                         Width="65" Height="48" Margin="0,0,6,0"
                         IsVisible="{Binding CommanderScryfallId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              <StackPanel Grid.Column="1" Spacing="1">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Format}" FontSize="11" Opacity="0.6" />
                <TextBlock Text="{Binding CommanderName}" FontSize="11" Opacity="0.75" FontStyle="Italic"
                           IsVisible="{Binding CommanderName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <controls:ManaSymbolsControl ManaCost="{Binding ColorIdentityMana}" Margin="0,2,0,0"
                           IsVisible="{Binding ColorIdentityMana, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </DockPanel>

    <!-- ══════════════════════════════════════════════════════════
         Col 1: Deck detail
         ══════════════════════════════════════════════════════════ -->
    <Grid x:Name="DeckPane" Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="4,8,4,8">

      <!-- Sidebar toggle — always visible -->
      <Button Grid.Row="0"
              Command="{Binding ToggleDeckSidebarCommand}"
              HorizontalAlignment="Left"
              Padding="6,3"
              Margin="0,0,0,4"
              FontSize="12">
        <StackPanel Orientation="Horizontal" Spacing="3">
          <TextBlock Text="◀" IsVisible="{Binding IsDeckSidebarOpen}" />
          <TextBlock Text="▶" IsVisible="{Binding !IsDeckSidebarOpen}" />
          <TextBlock Text="Decks" />
        </StackPanel>
      </Button>

      <!-- Header toolbar — compact icon bar -->
      <Border Grid.Row="1" Margin="0,0,0,4"
              IsVisible="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNotNull}}">
        <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">

          <!-- Deck name · format · count -->
          <TextBlock Text="{Binding SelectedDeck.Name}" FontSize="15" FontWeight="Bold"
                     VerticalAlignment="Center" MaxWidth="220" TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding SelectedDeck.Format}" Opacity="0.55" FontSize="11"
                     VerticalAlignment="Center" Margin="2,0,0,0" />
          <Border CornerRadius="4" Padding="5,2" VerticalAlignment="Center"
                  Background="{DynamicResource ThemeSurfaceVariantBrush}" Margin="2,0,0,0">
            <TextBlock Text="{Binding DeckCountText}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeTextPrimaryBrush}" />
          </Border>

          <!-- ─── divider ─── -->
          <Rectangle Width="1" Height="18" Margin="6,0" VerticalAlignment="Center"
                     Fill="{DynamicResource SystemControlForegroundBaseLowBrush}" Opacity="0.35" />

          <!-- View mode group (list/grid + sorted) -->
          <Border CornerRadius="6" Background="{DynamicResource ThemeSurfaceVariantBrush}" Padding="1">
            <StackPanel Orientation="Horizontal" Spacing="0">
              <Button Command="{Binding ToggleViewCommand}" Padding="7,4"
                      ToolTip.Tip="Toggle list / grid view">
                <StackPanel Orientation="Horizontal" Spacing="3">
                  <TextBlock Text="☰" IsVisible="{Binding !IsGridView}" FontSize="12" />
                  <TextBlock Text="⊞" IsVisible="{Binding IsGridView}" FontSize="12" />
                </StackPanel>
              </Button>
              <Button Command="{Binding ToggleSortedViewCommand}" Padding="7,4"
                      ToolTip.Tip="Sorted category view"
                      Classes.toolbarActive="{Binding IsSortedView}">
                <TextBlock Text="⊡" FontSize="12" />
              </Button>
            </StackPanel>
          </Border>

          <!-- ─── divider ─── -->
          <Rectangle Width="1" Height="18" Margin="6,0" VerticalAlignment="Center"
                     Fill="{DynamicResource SystemControlForegroundBaseLowBrush}" Opacity="0.35" />

          <!-- Panel toggles -->
          <Button Command="{Binding ToggleCollectionPaneCommand}" Padding="7,4"
                  ToolTip.Tip="Collection pane"
                  Classes.toolbarActive="{Binding IsCollectionPaneOpen}">
            <TextBlock Text="📚" FontSize="13" />
          </Button>
          <Button Command="{Binding ToggleScryfallPaneCommand}" Padding="7,4"
                  ToolTip.Tip="Scryfall search"
                  Classes.toolbarActive="{Binding IsScryfallPaneOpen}">
            <TextBlock Text="🔍" FontSize="13" />
          </Button>
          <Button Command="{Binding ToggleStatsPaneCommand}" Padding="7,4"
                  ToolTip.Tip="Deck stats"
                  IsEnabled="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNotNull}}"
                  Classes.toolbarActive="{Binding IsStatsPaneOpen}">
            <TextBlock Text="📈" FontSize="13" />
          </Button>
          <Button Command="{Binding ToggleHistoryPaneCommand}" Padding="7,4"
                  ToolTip.Tip="Version history"
                  IsEnabled="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNotNull}}"
                  Classes.toolbarActive="{Binding IsHistoryPaneOpen}">
            <TextBlock Text="🕓" FontSize="13" />
          </Button>

          <!-- ─── divider ─── -->
          <Rectangle Width="1" Height="18" Margin="6,0" VerticalAlignment="Center"
                     Fill="{DynamicResource SystemControlForegroundBaseLowBrush}" Opacity="0.35" />

          <!-- Deck actions menu -->
          <DropDownButton Padding="10,4" ToolTip.Tip="Deck actions">
            <DropDownButton.Content>
              <TextBlock Text="⋯" FontSize="15" />
            </DropDownButton.Content>
            <DropDownButton.Flyout>
              <MenuFlyout>
                <MenuItem Header="⇧  Share"
                          Command="{Binding ShareDeckCommand}"
                          IsEnabled="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <MenuItem Header="↑  Export to file"
                          Command="{Binding ExportDeckCommand}"
                          IsEnabled="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <MenuItem Header="↓  Import from file"
                          Command="{Binding ImportDeckCommand}" />
                <Separator />
                <MenuItem Header="🗑  Delete Deck"
                          Command="{Binding DeleteDeckCommand}"
                          IsEnabled="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNotNull}}" />
              </MenuFlyout>
            </DropDownButton.Flyout>
          </DropDownButton>

        </StackPanel>
      </Border>

      <!-- Duplicate / over-limit warning banner -->
      <Border Grid.Row="2"
              IsVisible="{Binding DuplicateWarning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
              Background="#442200" BorderBrush="#AA6633" BorderThickness="1"
              CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Text="{Binding DuplicateWarning}"
                     FontSize="12" TextWrapping="Wrap"
                     Foreground="#FFCC88" VerticalAlignment="Center" />
          <Button Grid.Column="1" Content="✕"
                  Command="{Binding ClearDuplicateWarningCommand}"
                  Padding="6,2" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <!-- Export / import status banner -->
      <Border Grid.Row="2"
              IsVisible="{Binding DeckTransferStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
              Background="#1E3A2F" BorderBrush="#2D6E50" BorderThickness="1"
              CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
        <TextBlock Text="{Binding DeckTransferStatus}"
                   FontSize="12" Foreground="#7DCFAA" VerticalAlignment="Center" />
      </Border>

      <!-- Commander info bar (Commander format only) -->
      <Border Grid.Row="3" Margin="0,0,0,6" Padding="8,6" CornerRadius="6"
              Background="{DynamicResource ThemeSurfaceBrush}"
              IsVisible="{Binding IsCommanderFormat}">
        <StackPanel Spacing="4">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Commander:" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="{Binding CommanderDeckCard.Card.Name}"
                       IsVisible="{Binding CommanderDeckCard, Converter={x:Static ObjectConverters.IsNotNull}}"
                       FontStyle="Italic" VerticalAlignment="Center" />
            <TextBlock Text="(none — right-click a row or use ⚔ button)"
                       IsVisible="{Binding CommanderDeckCard, Converter={x:Static ObjectConverters.IsNull}}"
                       Opacity="0.5" VerticalAlignment="Center" FontSize="11" />
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoadingCommanderColorIdentity}"
                         Width="60" Height="8" VerticalAlignment="Center" />
            <Button Content="Clear" Command="{Binding ClearCommanderCommand}"
                    IsVisible="{Binding CommanderDeckCard, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Padding="6,2" FontSize="11" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6"
                      IsVisible="{Binding CommanderDeckCard, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="Color identity:" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
            <TextBlock Text="{Binding CommanderColorIdentity}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
            <TextBlock IsVisible="{Binding IsColorFiltered}" FontSize="10" Opacity="0.6"
                       Text="(collection filtered to legal colors)" VerticalAlignment="Center" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- List / Grid area -->
      <Panel Grid.Row="4">
        <!-- List view -->
        <DataGrid x:Name="DeckListDataGrid"
                  ItemsSource="{Binding DeckCards}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal"
                  IsVisible="{Binding IsListViewMode}">
          <DataGrid.Styles>
            <Style Selector="DataGridRow">
              <Setter Property="ToolTip.Tip" Value="{Binding}" />
              <Setter Property="ToolTip.ShowDelay" Value="300" />
            </Style>
          </DataGrid.Styles>
          <DataGrid.DataTemplates>
            <DataTemplate DataType="models:DeckCard">
              <controls:CardImageControl Card="{Binding Card}" />
            </DataTemplate>
          </DataGrid.DataTemplates>
          <DataGrid.Columns>
            <DataGridTextColumn Header="Name" Binding="{Binding Card.Name}" Width="*" />
            <DataGridTextColumn Header="Set" Binding="{Binding Card.SetCode}" Width="45" />
            <DataGridTextColumn Header="#" Binding="{Binding Card.CollectorNumber}" Width="45" />
            <DataGridTemplateColumn Header="Foil" Width="45">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <CheckBox IsChecked="{Binding Card.Foil, Mode=OneWay}" IsHitTestVisible="False" HorizontalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="40" />
            <DataGridTemplateColumn Header="Sideboard" Width="70">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <CheckBox IsChecked="{Binding IsSideboard, Mode=OneWay}" IsHitTestVisible="False" HorizontalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="Cmdr" Width="55">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="models:DeckCard">
                  <CheckBox IsChecked="{Binding IsCommander, Mode=OneWay}" IsHitTestVisible="False" HorizontalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="" Width="85">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="models:DeckCard">
                  <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Content="⚔"
                            ToolTip.Tip="Set as Commander"
                            Command="{Binding $parent[DataGrid].((vm:DecksViewModel)DataContext).SetAsCommanderCommand}"
                            CommandParameter="{Binding}"
                            Padding="3,2" FontSize="11" />
                    <Button Content="✕"
                            ToolTip.Tip="Remove from deck"
                            Command="{Binding $parent[DataGrid].((vm:DecksViewModel)DataContext).RemoveCardFromDeckCommand}"
                            CommandParameter="{Binding}"
                            Padding="3,2" FontSize="11" />
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>

        <!-- Grid view -->
        <ScrollViewer x:Name="DeckGridScrollViewer" IsVisible="{Binding IsGridViewMode}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding DeckCardSlots}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CardSlotViewModel">
                <Border Width="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).TileWidth}"
                        Height="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).TileHeight}"
                        CornerRadius="8" ClipToBounds="True" Margin="5"
                        ToolTip.ShowDelay="200"
                        Background="{DynamicResource ThemeSurfaceVariantBrush}">
                  <Border.ContextMenu>
                    <ContextMenu x:CompileBindings="False">
                      <MenuItem Header="Remove from deck" Command="{Binding RemoveFromDeckCommand}" />
                      <Separator IsVisible="{Binding IsCommanderEligible}" />
                      <MenuItem Header="Set as Commander"
                                Command="{Binding SetAsCommanderCommand}"
                                IsVisible="{Binding IsCommanderEligible}" />
                    </ContextMenu>
                  </Border.ContextMenu>
                  <ToolTip.Tip>
                    <Border Background="#1A1A2A" CornerRadius="8" Padding="6">
                      <Panel>
                        <Image Source="{Binding Image}" MaxWidth="280" MaxHeight="392" Stretch="Uniform"
                               IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <TextBlock Text="{Binding Card.Name}" Foreground="White" FontSize="13" FontWeight="Bold"
                                   TextWrapping="Wrap" MaxWidth="268" Margin="4"
                                   IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}" />
                      </Panel>
                    </Border>
                  </ToolTip.Tip>
                  <Panel>
                    <Image Source="{Binding Image}" Stretch="UniformToFill"
                           IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsVisible="{Binding IsLoading}" Spacing="6">
                      <ProgressBar IsIndeterminate="True" Width="70" />
                      <TextBlock Text="{Binding Card.Name}" FontSize="10" TextWrapping="Wrap"
                                 HorizontalAlignment="Center" TextAlignment="Center" Opacity="0.6" MaxWidth="130" />
                    </StackPanel>
                    <Panel IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}">
                      <Panel IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                          <TextBlock Text="🃏" FontSize="28" HorizontalAlignment="Center" />
                          <TextBlock Text="{Binding Card.Name}" FontSize="10" TextWrapping="Wrap"
                                     MaxWidth="130" HorizontalAlignment="Center" TextAlignment="Center" />
                        </StackPanel>
                      </Panel>
                    </Panel>
                    <Border IsVisible="{Binding Card.Foil}"
                            Background="#88FFD700" CornerRadius="4"
                            Padding="4,2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4">
                      <TextBlock Text="✦ Foil" FontSize="9" FontWeight="Bold" Foreground="#805500" />
                    </Border>
                    <!-- Wanted overlay (not owned, on shopping list) -->
                    <Border IsVisible="{Binding IsWanted}"
                            Background="#99000000" CornerRadius="8">
                      <TextBlock Text="$" FontSize="48" FontWeight="Bold"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Foreground="#AAFFCC00" Opacity="0.75" />
                    </Border>
                    <Border Background="#AA000000" CornerRadius="0,0,8,8"
                            VerticalAlignment="Bottom" Padding="5,3">
                      <TextBlock Text="{Binding Card.Name}" FontSize="10" Foreground="White"
                                 TextTrimming="CharacterEllipsis" />
                    </Border>
                  </Panel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Sorted category view (compatible with list and grid modes) -->
        <ScrollViewer IsVisible="{Binding IsSortedView}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <!-- Horizontal grid: commander on left, categories fill the rest -->
          <Grid ColumnDefinitions="Auto,*" Margin="4,4,4,8">

            <!-- Commander column (only Commander-format decks) -->
            <StackPanel Grid.Column="0" Width="205" Spacing="4" Margin="0,0,10,0"
                        VerticalAlignment="Top"
                        IsVisible="{Binding ShowCommanderPanel}">
              <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,2">
                <TextBlock Text="♛" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Commander" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Opacity="0.65" FontSize="12" VerticalAlignment="Center"
                           IsVisible="{Binding CommanderDeckCard.Card.CurrentMarketPrice, Converter={x:Static ObjectConverters.IsNotNull}}"
                           Text="{Binding CommanderDeckCard.Card.CurrentMarketPrice, StringFormat=– $\{0:F2\}}" />
              </StackPanel>

              <!-- Card image — full card aspect ratio -->
              <Border Width="200" Height="279" CornerRadius="10" ClipToBounds="True"
                      Background="{DynamicResource ThemeSurfaceVariantBrush}">
                <Panel>
                  <Image Source="{Binding CommanderSlot.Image}" Stretch="UniformToFill"
                         IsVisible="{Binding CommanderSlot.Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                  <ProgressBar IsIndeterminate="True" Width="80" VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               IsVisible="{Binding CommanderSlot.IsLoading}" />
                  <TextBlock Text="No Commander" Opacity="0.4"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsVisible="{Binding CommanderDeckCard, Converter={x:Static ObjectConverters.IsNull}}" />
                </Panel>
              </Border>

              <TextBlock Text="{Binding CommanderDeckCard.Card.Name}"
                         FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"
                         IsVisible="{Binding CommanderDeckCard, Converter={x:Static ObjectConverters.IsNotNull}}" />
              <Button Content="Clear" Command="{Binding ClearCommanderCommand}" FontSize="11" Padding="6,2"
                      IsVisible="{Binding CommanderDeckCard, Converter={x:Static ObjectConverters.IsNotNull}}" />
            </StackPanel>

            <!-- Category columns — stretch-to-fill, wrap onto new rows as needed -->
            <ItemsControl Grid.Column="1" ItemsSource="{Binding DeckCategories}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <controls:UniformWrapPanel MinItemWidth="215" ItemSpacing="10" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DeckCategoryViewModel">
                  <StackPanel Spacing="0" Margin="0,0,0,10">

                    <!-- Column header -->
                    <Border Background="{DynamicResource ThemeSurfaceBrush}"
                            CornerRadius="4,4,0,0" Padding="8,6">
                      <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CountLabel}" Opacity="0.55" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PriceLabel}" Opacity="0.65" FontSize="12" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Border>

                    <!-- List rows (when grid is off) -->
                    <Border Background="{DynamicResource ThemeSurfaceVariantBrush}"
                            CornerRadius="0,0,4,4" Padding="0,2"
                            IsVisible="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).IsGridView, Converter={x:Static BoolConverters.Not}}">
                      <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:DeckCardSortedItem">
                            <Border Padding="8,6"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="0,0,0,1">
                              <Border.ContextMenu>
                                <ContextMenu x:CompileBindings="False">
                                  <MenuItem Header="Remove from deck" Command="{Binding RemoveCommand}" />
                                  <Separator IsVisible="{Binding IsCommanderEligible}" />
                                  <MenuItem Header="Set as Commander"
                                            Command="{Binding PromoteToCommanderCommand}"
                                            IsVisible="{Binding IsCommanderEligible}" />
                                </ContextMenu>
                              </Border.ContextMenu>
                              <Grid ColumnDefinitions="Auto,*,Auto,Auto">

                                <!-- Quantity badge (only when qty > 1) -->
                                <Border Grid.Column="0"
                                        Background="#44E8C840" CornerRadius="3"
                                        Padding="5,2" Margin="0,0,6,0" MinWidth="20"
                                        IsVisible="{Binding DeckCard.Quantity, Converter={StaticResource IntGreaterThanOneConverter}}">
                                  <TextBlock Text="{Binding DeckCard.Quantity}" FontSize="11" FontWeight="Bold"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Card name -->
                                <TextBlock Grid.Column="1" Text="{Binding DeckCard.Card.Name}" FontSize="13"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                                <!-- Mana cost symbols -->
                                <controls:ManaSymbolsControl Grid.Column="2"
                                    ManaCost="{Binding DeckCard.Card.ManaCost}" Margin="5,0"
                                    IsVisible="{Binding DeckCard.Card.ManaCost, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                <!-- Owned / wanted indicator -->
                                <Border Grid.Column="3" Width="17" Height="17" CornerRadius="9"
                                        Background="#2080C8" VerticalAlignment="Center"
                                        IsVisible="{Binding IsOwned}">
                                  <TextBlock Text="✓" FontSize="10" FontWeight="Bold" Foreground="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="3" Width="17" Height="17" CornerRadius="9"
                                        Background="#C8A000" VerticalAlignment="Center"
                                        IsVisible="{Binding IsWanted}">
                                  <TextBlock Text="$" FontSize="10" FontWeight="Bold" Foreground="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Border>

                    <!-- Grid tiles (when grid is on) -->
                    <Border Background="{DynamicResource ThemeSurfaceVariantBrush}"
                            CornerRadius="0,0,4,4" Padding="4"
                            IsVisible="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).IsGridView}">
                      <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:DeckCardSortedItem">
                            <Border Width="130" Height="182" CornerRadius="8" ClipToBounds="True"
                                    Margin="3" Background="{DynamicResource ThemeSurfaceVariantBrush}"
                                    ToolTip.ShowDelay="200">
                              <Border.ContextMenu>
                                <ContextMenu x:CompileBindings="False">
                                  <MenuItem Header="Remove from deck" Command="{Binding RemoveCommand}" />
                                  <Separator IsVisible="{Binding IsCommanderEligible}" />
                                  <MenuItem Header="Set as Commander"
                                            Command="{Binding PromoteToCommanderCommand}"
                                            IsVisible="{Binding IsCommanderEligible}" />
                                </ContextMenu>
                              </Border.ContextMenu>
                              <ToolTip.Tip>
                                <Border Background="#1A1A2A" CornerRadius="8" Padding="6">
                                  <Panel>
                                    <Image Source="{Binding Slot.Image}" MaxWidth="280" MaxHeight="392" Stretch="Uniform"
                                           IsVisible="{Binding Slot.Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    <TextBlock Text="{Binding DeckCard.Card.Name}" Foreground="White"
                                               FontSize="13" FontWeight="Bold" TextWrapping="Wrap"
                                               MaxWidth="268" Margin="4"
                                               IsVisible="{Binding Slot.Image, Converter={x:Static ObjectConverters.IsNull}}" />
                                  </Panel>
                                </Border>
                              </ToolTip.Tip>
                              <Panel>
                                <Image Source="{Binding Slot.Image}" Stretch="UniformToFill"
                                       IsVisible="{Binding Slot.Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                            IsVisible="{Binding Slot.IsLoading}" Spacing="4">
                                  <ProgressBar IsIndeterminate="True" Width="70" />
                                  <TextBlock Text="{Binding DeckCard.Card.Name}" FontSize="9"
                                             TextWrapping="Wrap" HorizontalAlignment="Center"
                                             TextAlignment="Center" Opacity="0.6" MaxWidth="120" />
                                </StackPanel>
                                <StackPanel IsVisible="{Binding Slot.IsLoading, Converter={x:Static BoolConverters.Not}}">
                                  <Panel IsVisible="{Binding Slot.Image, Converter={x:Static ObjectConverters.IsNull}}">
                                    <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                      <TextBlock Text="🃏" FontSize="28" HorizontalAlignment="Center" />
                                      <TextBlock Text="{Binding DeckCard.Card.Name}" FontSize="10"
                                                 TextWrapping="Wrap" MaxWidth="118"
                                                 HorizontalAlignment="Center" TextAlignment="Center" />
                                    </StackPanel>
                                  </Panel>
                                </StackPanel>
                                <!-- Quantity badge -->
                                <Border IsVisible="{Binding DeckCard.Quantity, Converter={StaticResource IntGreaterThanOneConverter}}"
                                        Background="#AA000000" CornerRadius="3" Padding="4,2"
                                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="4">
                                  <TextBlock Text="{Binding DeckCard.Quantity}" FontSize="11"
                                             FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <Border Background="#AA000000" CornerRadius="0,0,8,8"
                                        VerticalAlignment="Bottom" Padding="5,3">
                                  <TextBlock Text="{Binding DeckCard.Card.Name}" FontSize="10"
                                             Foreground="White" TextTrimming="CharacterEllipsis" />
                                </Border>
                              </Panel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Border>

                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </Grid>
        </ScrollViewer>

        <TextBlock Text="Select a deck to view its cards."
                   IsVisible="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNull}}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" />
      </Panel>
    </Grid>

    <!-- Splitter between deck detail and collection pane -->
    <GridSplitter Grid.Column="2"
                  ResizeDirection="Columns"
                  Background="Transparent"
                  Width="5" HorizontalAlignment="Stretch"
                  IsVisible="{Binding IsCollectionPaneOpen}" />

    <!-- ══════════════════════════════════════════════════════════
         Col 3: Collection pane (collapsible / pop-out)
         ══════════════════════════════════════════════════════════ -->
    <Border x:Name="CollectionPaneRoot" Grid.Column="3" Margin="{Binding SidePaneBottomMargin}"
            Background="{DynamicResource ThemeSurfaceBrush}"
            CornerRadius="8"
            IsVisible="{Binding IsCollectionPaneOpen}">
      <views:CollectionPaneView x:Name="CollectionPane" />
    </Border>

    <!-- Splitter between collection pane and Scryfall pane -->
    <GridSplitter Grid.Column="4"
                  ResizeDirection="Columns"
                  Background="Transparent"
                  Width="5" HorizontalAlignment="Stretch"
                  IsVisible="{Binding IsScryfallPaneOpen}" />

    <!-- ══════════════════════════════════════════════════════════
         Col 5: Scryfall search pane (collapsible / pop-out)
         ══════════════════════════════════════════════════════════ -->
    <Border Grid.Column="5" Margin="{Binding SidePaneBottomMargin}"
            Background="{DynamicResource ThemeSurfaceBrush}"
            CornerRadius="8"
            IsVisible="{Binding IsScryfallPaneOpen}">
      <views:ScryfallPaneView x:Name="ScryfallPane" />
    </Border>

    <!-- Splitter between Scryfall pane and stats pane -->
    <GridSplitter Grid.Column="6"
                  ResizeDirection="Columns"
                  Background="Transparent"
                  Width="5" HorizontalAlignment="Stretch"
                  IsVisible="{Binding IsStatsPaneOpen}" />

    <!-- ══════════════════════════════════════════════════════════
         Col 7: Deck stats pane (collapsible)
         ══════════════════════════════════════════════════════════ -->
    <Border Grid.Column="7" Margin="{Binding SidePaneBottomMargin}"
            Background="{DynamicResource ThemeSurfaceBrush}"
            CornerRadius="8"
            IsVisible="{Binding IsStatsPaneOpen}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10" Margin="10,8,10,10">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Deck Stats" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" />
            <TextBlock Text="{Binding SelectedDeck.Name}" Opacity="0.65" FontSize="11"
                       VerticalAlignment="Center"
                       IsVisible="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNotNull}}" />
          </StackPanel>

          <Border Background="{DynamicResource ThemeSurfaceVariantBrush}" CornerRadius="6" Padding="8"
                  IsVisible="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNull}}">
            <TextBlock Text="Select a deck to view stats." Opacity="0.7" />
          </Border>

          <StackPanel Spacing="10" IsVisible="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Border Background="{DynamicResource ThemeSurfaceVariantBrush}" CornerRadius="6" Padding="8">
              <StackPanel Spacing="6">
                <TextBlock Text="Mana Curve (non-lands)" FontWeight="SemiBold" FontSize="12" />
                <ItemsControl ItemsSource="{Binding DeckCurveBins}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeckCurveBinViewModel">
                      <Grid ColumnDefinitions="26,*,28" Margin="0,1,0,1">
                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11" VerticalAlignment="Center" />
                        <Border Grid.Column="1" Height="12" Background="#22000000" CornerRadius="3">
                          <Border Height="12" HorizontalAlignment="Left"
                                  Width="{Binding BarWidth}" CornerRadius="3"
                                  Background="#6690B8FF" />
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="11" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceVariantBrush}" CornerRadius="6" Padding="8">
              <StackPanel Spacing="4">
                <TextBlock Text="Gameplay" FontWeight="SemiBold" FontSize="12" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Mean turn to first land miss" Opacity="0.75" />
                  <TextBlock Grid.Column="1" Text="{Binding MeanTurnsToFirstLandMissText}" FontWeight="SemiBold" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Avg lands in first hand" Opacity="0.75" />
                  <TextBlock Grid.Column="1" Text="{Binding MeanLandsInFirstHandText}" FontWeight="SemiBold" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceVariantBrush}" CornerRadius="6" Padding="8">
              <StackPanel Spacing="6">
                <TextBlock Text="Lands" FontWeight="SemiBold" FontSize="12" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Total lands" Opacity="0.75" />
                  <TextBlock Grid.Column="1" Text="{Binding DeckLandCount}" FontWeight="SemiBold" />
                </Grid>
                <TextBlock FontSize="10" Opacity="0.7"
                           IsVisible="{Binding HasActiveDeckColorFilter}">
                  <Run Text="Deck filter: " />
                  <Run Text="{Binding ActiveDeckColorFilterText}" />
                  <Run Text=" (tap active color to clear)" />
                </TextBlock>
                <ItemsControl ItemsSource="{Binding LandColorHistogram}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeckColorHistogramItemViewModel">
                      <Button Command="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).ToggleDeckColorFilterCommand}"
                              CommandParameter="{Binding Label}"
                              Opacity="{Binding RowOpacity}"
                              Background="Transparent" BorderBrush="Transparent" Padding="0"
                              HorizontalContentAlignment="Stretch">
                        <Grid ColumnDefinitions="22,*,30" Margin="0,1,0,1">
                          <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11" VerticalAlignment="Center" />
                          <Border Grid.Column="1" Height="14" Background="#22000000" CornerRadius="3">
                            <Grid>
                              <Border Height="14" HorizontalAlignment="Left" Width="{Binding BarWidth}" CornerRadius="3"
                                      Background="{Binding BarColor}">
                                <TextBlock Text="{Binding Count}" FontSize="10" FontWeight="SemiBold"
                                           HorizontalAlignment="Right" Margin="0,0,4,0"
                                           VerticalAlignment="Center" Foreground="{Binding TextColor}" />
                              </Border>
                              <Border BorderBrush="#C0FFFFFF" BorderThickness="1" CornerRadius="3"
                                      IsVisible="{Binding IsActive}" />
                            </Grid>
                          </Border>
                          <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="11" HorizontalAlignment="Right"
                                     VerticalAlignment="Center" />
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceVariantBrush}" CornerRadius="6" Padding="8">
              <StackPanel Spacing="6">
                <TextBlock Text="Cards by Color" FontWeight="SemiBold" FontSize="12" />
                <ItemsControl ItemsSource="{Binding CardColorHistogram}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeckColorHistogramItemViewModel">
                      <Button Command="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).ToggleDeckColorFilterCommand}"
                              CommandParameter="{Binding Label}"
                              Opacity="{Binding RowOpacity}"
                              Background="Transparent" BorderBrush="Transparent" Padding="0"
                              HorizontalContentAlignment="Stretch">
                        <Grid ColumnDefinitions="22,*,30" Margin="0,1,0,1">
                          <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11" VerticalAlignment="Center" />
                          <Border Grid.Column="1" Height="14" Background="#22000000" CornerRadius="3">
                            <Grid>
                              <Border Height="14" HorizontalAlignment="Left" Width="{Binding BarWidth}" CornerRadius="3"
                                      Background="{Binding BarColor}">
                                <TextBlock Text="{Binding Count}" FontSize="10" FontWeight="SemiBold"
                                           HorizontalAlignment="Right" Margin="0,0,4,0"
                                           VerticalAlignment="Center" Foreground="{Binding TextColor}" />
                              </Border>
                              <Border BorderBrush="#C0FFFFFF" BorderThickness="1" CornerRadius="3"
                                      IsVisible="{Binding IsActive}" />
                            </Grid>
                          </Border>
                          <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="11" HorizontalAlignment="Right"
                                     VerticalAlignment="Center" />
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceVariantBrush}" CornerRadius="6" Padding="8">
              <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Game Performance" FontWeight="SemiBold" FontSize="12" />
                  <TextBlock Text="{Binding DeckGameTotal, StringFormat='({0} games)'}"
                             FontSize="11" Opacity="0.6" VerticalAlignment="Center" />
                </StackPanel>
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
                  <Border Grid.Column="0" Background="#1E3A2F" CornerRadius="4" Padding="6,4">
                    <StackPanel HorizontalAlignment="Center" Spacing="1">
                      <TextBlock Text="{Binding DeckGameWins}" FontSize="16" FontWeight="Bold"
                                 Foreground="#7DCFAA" HorizontalAlignment="Center" />
                      <TextBlock Text="Wins" FontSize="10" Opacity="0.7" HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="1" Background="#3A1E1E" CornerRadius="4" Padding="6,4">
                    <StackPanel HorizontalAlignment="Center" Spacing="1">
                      <TextBlock Text="{Binding DeckGameLosses}" FontSize="16" FontWeight="Bold"
                                 Foreground="#CF7D7D" HorizontalAlignment="Center" />
                      <TextBlock Text="Losses" FontSize="10" Opacity="0.7" HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="2" Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="4" Padding="6,4">
                    <StackPanel HorizontalAlignment="Center" Spacing="1">
                      <TextBlock Text="{Binding DeckGameWinRateText}" FontSize="16" FontWeight="Bold"
                                 HorizontalAlignment="Center" />
                      <TextBlock Text="Win Rate" FontSize="10" Opacity="0.7" HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Grid>
                <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                  <TextBlock Grid.Column="0" Text="Avg win turn" Opacity="0.7" FontSize="11" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding DeckAvgWinTurnText}" FontWeight="SemiBold" FontSize="11" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Avg loss turn" Opacity="0.7" FontSize="11" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding DeckAvgLossTurnText}" FontWeight="SemiBold" FontSize="11" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceVariantBrush}" CornerRadius="6" Padding="8">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Total Price" FontWeight="SemiBold" FontSize="12" />
                <TextBlock Grid.Column="1" Text="{Binding DeckTotalPriceText}" FontWeight="Bold" FontSize="13" />
              </Grid>
            </Border>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Splitter between stats pane and history pane -->
    <GridSplitter Grid.Column="8"
                  ResizeDirection="Columns"
                  Background="Transparent"
                  Width="5" HorizontalAlignment="Stretch"
                  IsVisible="{Binding IsHistoryPaneOpen}" />

    <!-- ══════════════════════════════════════════════════════════
         Col 9: Version history pane (collapsible)
         ══════════════════════════════════════════════════════════ -->
    <Border Grid.Column="9" Margin="{Binding SidePaneBottomMargin}"
            Background="{DynamicResource ThemeSurfaceBrush}"
            CornerRadius="8"
            IsVisible="{Binding IsHistoryPaneOpen}">
      <DockPanel>

        <!-- Header + save form -->
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="10,8,10,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Version History" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" />
            <TextBlock Text="{Binding SelectedDeck.Name}" Opacity="0.65" FontSize="11"
                       VerticalAlignment="Center"
                       IsVisible="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNotNull}}" />
          </StackPanel>

          <!-- Save a named version -->
          <Border Background="{DynamicResource ThemeSurfaceVariantBrush}" CornerRadius="6" Padding="8">
            <StackPanel Spacing="6">
              <TextBlock Text="Save snapshot" FontWeight="SemiBold" FontSize="11" />
              <TextBox Text="{Binding NewVersionLabel}" Watermark="Label (optional)" FontSize="11" Height="28" Padding="6,3" />
              <Button Content="Save Version" Command="{Binding SaveVersionCommand}"
                      Classes="accent" FontSize="11"
                      IsEnabled="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNotNull}}" />
            </StackPanel>
          </Border>

          <!-- Diff summary -->
          <Border Background="{DynamicResource ThemeSurfaceVariantBrush}" CornerRadius="6" Padding="8"
                  IsVisible="{Binding DiffSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Diff:" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" />
                <TextBlock Text="{Binding DiffSummary}" FontSize="11" VerticalAlignment="Center" />
                <Button Content="✕" Command="{Binding ClearVersionSelectionCommand}"
                        Padding="5,2" FontSize="10" />
              </StackPanel>
              <TextBlock Text="{Binding SelectedVersionA.DisplayLabel}" FontSize="10" Opacity="0.7"
                         IsVisible="{Binding SelectedVersionA, Converter={x:Static ObjectConverters.IsNotNull}}" />
              <TextBlock Text="vs." FontSize="10" Opacity="0.5"
                         IsVisible="{Binding SelectedVersionB, Converter={x:Static ObjectConverters.IsNotNull}}" />
              <TextBlock FontSize="10" Opacity="0.7"
                         IsVisible="{Binding SelectedVersionB, Converter={x:Static ObjectConverters.IsNotNull}}"
                         Text="{Binding SelectedVersionB.DisplayLabel}" />
              <TextBlock Text="vs. current deck" FontSize="10" Opacity="0.5"
                         IsVisible="{Binding SelectedVersionB, Converter={x:Static ObjectConverters.IsNull}}" />
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Diff entries -->
        <ScrollViewer DockPanel.Dock="Bottom" VerticalScrollBarVisibility="Auto" Margin="10,6,10,8"
                      IsVisible="{Binding VersionDiff.Count}">
          <ItemsControl ItemsSource="{Binding VersionDiff}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:DeckDiffEntryViewModel">
                <Border CornerRadius="4" Padding="7,4" Margin="0,1"
                        Background="{Binding RowColor}">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="{Binding CardName}" FontSize="12" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding SetCode}" FontSize="10" Opacity="0.55" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding ChangeLabel}"
                               Foreground="{Binding ChangeLabelColor}"
                               FontWeight="Bold" FontSize="12"
                               VerticalAlignment="Center" Margin="6,0,0,0" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Version list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10,6,10,0">
          <StackPanel Spacing="2">
            <TextBlock Text="No versions saved yet." FontSize="11" Opacity="0.5"
                       IsVisible="{Binding !DeckVersions.Count}" Margin="0,4" />
            <ItemsControl ItemsSource="{Binding DeckVersions}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DeckVersionViewModel">
                  <Border CornerRadius="5" Padding="8,6" Margin="0,1"
                          Background="{DynamicResource ThemeSurfaceVariantBrush}">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding DisplayLabel}" FontSize="11" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="auto" FontSize="9" Opacity="0.45"
                                   IsVisible="{Binding IsAuto}" />
                      </StackPanel>
                      <Button Grid.Column="1" Content="A"
                              ToolTip.Tip="Set as 'from' version for diff"
                              Command="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).SelectVersionACommand}"
                              CommandParameter="{Binding}"
                              Classes.accent="{Binding IsSelectedA}"
                              Padding="5,3" FontSize="11" FontWeight="Bold" Margin="4,0,0,0" />
                      <Button Grid.Column="2" Content="B"
                              ToolTip.Tip="Set as 'to' version for diff (leave unset to diff against current deck)"
                              Command="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).SelectVersionBCommand}"
                              CommandParameter="{Binding}"
                              Classes.accent="{Binding IsSelectedB}"
                              Padding="5,3" FontSize="11" FontWeight="Bold" Margin="4,0,0,0" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>

      </DockPanel>
    </Border>

  <!-- Drag preview overlay (spans full Grid, sits on top, no hit testing) -->
  <Canvas x:Name="DragOverlay" Grid.ColumnSpan="10" IsHitTestVisible="False" IsVisible="False">
    <Border x:Name="DragPreview" Width="90" Height="126" CornerRadius="6"
            ClipToBounds="True" Opacity="0.92"
            Background="{DynamicResource SystemControlBackgroundBaseMediumBrush}">
      <Panel>
        <Image x:Name="DragPreviewImage" Stretch="UniformToFill" />
        <Border VerticalAlignment="Bottom" Background="#AA000000"
                Padding="4,2" CornerRadius="0,0,6,6">
          <TextBlock x:Name="DragPreviewName" FontSize="9" Foreground="White"
                     TextTrimming="CharacterEllipsis" />
        </Border>
      </Panel>
    </Border>
  </Canvas>

  </Grid>  <!-- end RootGrid -->

  <!-- ── Card detail panel — floats bottom-right over the grid ────────── -->
  <Border IsVisible="{Binding IsCardDetailOpen}"
          VerticalAlignment="Bottom"
          HorizontalAlignment="Right"
          Width="504"
          Height="270"
          Background="{DynamicResource ThemeSurfaceHighBrush}"
          BorderBrush="{DynamicResource ThemeBorderBrush}"
          BorderThickness="1,1,0,0"
          CornerRadius="8,0,0,0"
          Padding="12,10">
    <Grid ColumnDefinitions="Auto,*" Width="480">

      <!-- Card image — full card, no crop -->
      <Border Grid.Column="0" CornerRadius="6" ClipToBounds="False"
              Background="{DynamicResource ThemeSurfaceVariantBrush}" Margin="0,0,14,0"
              VerticalAlignment="Center">
        <Panel>
          <Image Source="{Binding DetailSlot.Image}" Stretch="Uniform"
                 MaxWidth="175" MaxHeight="245"
                 IsVisible="{Binding DetailSlot.Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
          <Border Width="145" Height="203"
                  IsVisible="{Binding DetailSlot.Image, Converter={x:Static ObjectConverters.IsNull}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
              <ProgressBar IsIndeterminate="True" Width="80"
                           IsVisible="{Binding DetailSlot.IsLoading}" />
              <TextBlock Text="{Binding DetailSlot.Card.Name}"
                         Foreground="White" FontSize="11" TextWrapping="Wrap"
                         HorizontalAlignment="Center" TextAlignment="Center" Margin="6"
                         IsVisible="{Binding !DetailSlot.IsLoading}" />
            </StackPanel>
          </Border>
        </Panel>
      </Border>

      <!-- Card text — oracle text fills remaining height -->
      <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">

        <!-- Name + close -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
          <TextBlock Grid.Column="0" Text="{Binding DetailSlot.Card.Name}"
                     FontSize="15" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center" />
          <Button Grid.Column="1" Content="✕" Command="{Binding CloseCardDetailCommand}"
                  Padding="8,4" FontSize="12" VerticalAlignment="Top" />
        </Grid>

        <!-- Mana cost -->
        <controls:ManaSymbolsControl Grid.Row="1" ManaCost="{Binding DetailSlot.Card.ManaCost}"
                                     Margin="0,0,0,3"
                                     IsVisible="{Binding DetailSlot.Card.ManaCost, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- Type line -->
        <TextBlock Grid.Row="2" Text="{Binding DetailSlot.Card.TypeLine}"
                   FontSize="11" Opacity="0.8" TextWrapping="Wrap" Margin="0,0,0,3"
                   IsVisible="{Binding DetailSlot.Card.TypeLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- Set · # · Rarity -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="4" Margin="0,0,0,6">
          <TextBlock Text="{Binding DetailSlot.Card.SetCode}" FontSize="10" Opacity="0.55" />
          <TextBlock Text="·" FontSize="10" Opacity="0.4" />
          <TextBlock Text="{Binding DetailSlot.Card.CollectorNumber}" FontSize="10" Opacity="0.55" />
          <TextBlock Text="·" FontSize="10" Opacity="0.4" />
          <TextBlock Text="{Binding DetailSlot.Card.Rarity}" FontSize="10" Opacity="0.55" />
        </StackPanel>

        <!-- Oracle text (scrollable, fills remaining space) -->
        <Border Grid.Row="4"
                Background="{DynamicResource ThemeSurfaceVariantBrush}"
                CornerRadius="4" Padding="6,5" Margin="0,0,0,5"
                IsVisible="{Binding HasDetailOracleText}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <controls:OracleTextControl OracleText="{Binding DetailOracleText}"
                                        FontSize="11" />
          </ScrollViewer>
        </Border>

        <!-- P/T or Loyalty -->
        <TextBlock Grid.Row="5" Text="{Binding DetailPowerToughness}"
                   FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"
                   Margin="0,0,0,3"
                   IsVisible="{Binding HasDetailPowerToughness}" />

        <!-- Price -->
        <TextBlock Grid.Row="6" FontSize="12" FontWeight="SemiBold"
                   IsVisible="{Binding DetailSlot.Card.CurrentMarketPrice, Converter={x:Static ObjectConverters.IsNotNull}}"
                   Text="{Binding DetailSlot.Card.CurrentMarketPrice, StringFormat=$\{0:F2\}}" />

      </Grid>
    </Grid>
  </Border>

  </Panel>
</UserControl>
