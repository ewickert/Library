<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Library.ViewModels"
             xmlns:models="using:Library.Models"
             xmlns:converters="using:Library.Views"
             xmlns:controls="using:Library.Views.Controls"
             x:Class="Library.Views.GamesView"
             x:DataType="vm:GamesViewModel">

  <Grid ColumnDefinitions="5*,5,8*" Margin="8">

    <!-- ══════════════════════════════════════════════════════════
         Col 0: Statistics
         ══════════════════════════════════════════════════════════ -->
    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="10" Margin="0,0,8,0">

        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Text="Statistics" FontWeight="Bold" FontSize="14"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1" Content="+ Log Game" Command="{Binding StartLogGameCommand}"
                  Classes="accent" Padding="12,5" FontSize="12" />
        </Grid>

        <!-- ── My Record ── -->
        <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
              <Border Grid.Column="0" Background="#1E3A2F" CornerRadius="6" Padding="8,6">
                <StackPanel HorizontalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding TotalWins}" FontSize="22" FontWeight="Bold"
                             Foreground="#7DCFAA" HorizontalAlignment="Center" />
                  <TextBlock Text="Wins" FontSize="11" Opacity="0.7" HorizontalAlignment="Center" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Background="#3A1E1E" CornerRadius="6" Padding="8,6">
                <StackPanel HorizontalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding TotalLosses}" FontSize="22" FontWeight="Bold"
                             Foreground="#CF7D7D" HorizontalAlignment="Center" />
                  <TextBlock Text="Losses" FontSize="11" Opacity="0.7" HorizontalAlignment="Center" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Background="{DynamicResource ThemeSurfaceVariantBrush}" CornerRadius="6" Padding="8,6">
                <StackPanel HorizontalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding WinRateText}" FontSize="22" FontWeight="Bold"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="Win Rate" FontSize="11" Opacity="0.7" HorizontalAlignment="Center" />
                </StackPanel>
              </Border>
              <Border Grid.Column="3" Background="{DynamicResource ThemeSurfaceVariantBrush}" CornerRadius="6" Padding="8,6">
                <StackPanel HorizontalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding TotalGames}" FontSize="22" FontWeight="Bold"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="Games" FontSize="11" Opacity="0.7" HorizontalAlignment="Center" />
                </StackPanel>
              </Border>
            </Grid>

            <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
              <TextBlock Grid.Column="0" Text="Avg turn won"  Opacity="0.7" FontSize="12" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding AvgWinTurnText}"  FontWeight="SemiBold" FontSize="12" />
            </Grid>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Avg turn lost" Opacity="0.7" FontSize="12" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding AvgLossTurnText}" FontWeight="SemiBold" FontSize="12" />
            </Grid>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Last 30 days"  Opacity="0.7" FontSize="12" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding GamesLast30Days, StringFormat='{}{0} games'}"
                         FontWeight="SemiBold" FontSize="12" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- ── Streak ── -->
        <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12"
                IsVisible="{Binding TotalGames}">
          <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="3">
              <TextBlock Text="{Binding CurrentStreakText}" FontSize="28" FontWeight="Bold"
                         HorizontalAlignment="Center"
                         Foreground="{Binding CurrentStreakIsWin, Converter={x:Static converters:BoolToWinColorConverter.Instance}}" />
              <TextBlock Text="Current streak" FontSize="11" Opacity="0.6" HorizontalAlignment="Center" />
            </StackPanel>
            <Border Grid.Column="1" Width="1" Background="{DynamicResource ThemeSurfaceVariantBrush}" />
            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="3">
              <TextBlock Text="{Binding BestWinStreakText}" FontSize="28" FontWeight="Bold"
                         Foreground="#7DCFAA" HorizontalAlignment="Center" />
              <TextBlock Text="Best win streak" FontSize="11" Opacity="0.6" HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- ── Deck performance ── -->
        <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12"
                IsVisible="{Binding DeckStats.Count}">
          <StackPanel Spacing="8">
            <TextBlock Text="By deck" FontWeight="SemiBold" FontSize="12" />
            <ItemsControl ItemsSource="{Binding DeckStats}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DeckStatViewModel">
                  <Grid ColumnDefinitions="34,*,54" ColumnSpacing="8" Margin="0,3">
                    <!-- Commander art / placeholder -->
                    <controls:ArtCropControl Grid.Column="0" Width="34" Height="26"
                      ScryfallId="{Binding CommanderScryfallId}"
                      IsVisible="{Binding HasCommanderArt}"
                      VerticalAlignment="Center" />
                    <Border Grid.Column="0" Width="34" Height="26" CornerRadius="4"
                            Background="#2D2D2D"
                            IsVisible="{Binding !HasCommanderArt}"
                            VerticalAlignment="Center">
                      <TextBlock Text="?" FontSize="14" FontWeight="Light" Opacity="0.25"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <!-- Name + win bar -->
                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                      <TextBlock Text="{Binding DeckName}" FontSize="12" TextTrimming="CharacterEllipsis" />
                      <Border Height="7" Background="#22FFFFFF" CornerRadius="3">
                        <Border Height="7" HorizontalAlignment="Left" Width="{Binding WinBarWidth}"
                                CornerRadius="3" Background="#667DCFAA" />
                      </Border>
                    </StackPanel>
                    <!-- Record -->
                    <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                      <TextBlock Text="{Binding WinRateText}" FontSize="12" FontWeight="SemiBold"
                                 HorizontalAlignment="Right" />
                      <TextBlock Text="{Binding RecordText}" FontSize="10" Opacity="0.5"
                                 HorizontalAlignment="Right" />
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- ── Win rate by player count ── -->
        <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12"
                IsVisible="{Binding PlayerCountStats.Count}">
          <StackPanel Spacing="8">
            <TextBlock Text="By player count" FontWeight="SemiBold" FontSize="12" />
            <ItemsControl ItemsSource="{Binding PlayerCountStats}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:PlayerCountStatViewModel">
                  <Grid ColumnDefinitions="28,*,44,44" ColumnSpacing="8" Margin="0,2">
                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12" FontWeight="SemiBold"
                               Opacity="0.75" VerticalAlignment="Center" />
                    <Border Grid.Column="1" Height="8" Background="#22FFFFFF" CornerRadius="3"
                            VerticalAlignment="Center">
                      <Border Height="8" HorizontalAlignment="Left" Width="{Binding WinBarWidth}"
                              CornerRadius="3" Background="#667DCFAA" />
                    </Border>
                    <TextBlock Grid.Column="2" Text="{Binding WinRateText}" FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="{Binding GamesText}" FontSize="10" Opacity="0.5"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- ── Turn distributions ── -->
        <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12"
                IsVisible="{Binding WinTurnBins.Count}">
          <StackPanel Spacing="6">
            <TextBlock Text="Win turn distribution" FontWeight="SemiBold" FontSize="12" />
            <ItemsControl ItemsSource="{Binding WinTurnBins}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DeckCurveBinViewModel">
                  <Grid ColumnDefinitions="44,*,28" Margin="0,1">
                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                    <Border Grid.Column="1" Height="10" Background="#22FFFFFF" CornerRadius="3">
                      <Border Height="10" HorizontalAlignment="Left" Width="{Binding BarWidth}"
                              CornerRadius="3" Background="#667DCFAA" />
                    </Border>
                    <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="11"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12"
                IsVisible="{Binding LossTurnBins.Count}">
          <StackPanel Spacing="6">
            <TextBlock Text="Loss turn distribution" FontWeight="SemiBold" FontSize="12" />
            <ItemsControl ItemsSource="{Binding LossTurnBins}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DeckCurveBinViewModel">
                  <Grid ColumnDefinitions="44,*,28" Margin="0,1">
                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                    <Border Grid.Column="1" Height="10" Background="#22FFFFFF" CornerRadius="3">
                      <Border Height="10" HorizontalAlignment="Left" Width="{Binding BarWidth}"
                              CornerRadius="3" Background="#66CF7D7D" />
                    </Border>
                    <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="11"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- Splitter -->
    <GridSplitter Grid.Column="1" ResizeDirection="Columns"
                  Background="Transparent" Width="5" HorizontalAlignment="Stretch" />

    <!-- ══════════════════════════════════════════════════════════
         Col 2: Game history
         ══════════════════════════════════════════════════════════ -->
    <DockPanel Grid.Column="2">
      <TextBlock DockPanel.Dock="Top" Text="Game History"
                 FontWeight="Bold" FontSize="13" Margin="0,0,0,8" />

      <!-- Empty state -->
      <Border DockPanel.Dock="Top"
              Background="{DynamicResource ThemeSurfaceBrush}"
              CornerRadius="8" Padding="16"
              IsVisible="{Binding !Games.Count}">
        <TextBlock Text="No games logged yet. Use '+ Log Game' to record your first game."
                   Opacity="0.6" TextWrapping="Wrap" />
      </Border>

      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Games}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:Game">
              <Border Background="{DynamicResource ThemeSurfaceBrush}"
                      CornerRadius="8" Padding="12" Margin="0,0,0,8">
                <StackPanel Spacing="10">

                  <!-- ── Commander art gallery ── -->
                  <ItemsControl ItemsSource="{Binding Players}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="models:GamePlayer">
                        <StackPanel Width="100" Margin="0,0,8,0" Spacing="0">
                          <!-- Art (or placeholder) with overlay badges -->
                          <Border CornerRadius="6,6,0,0" ClipToBounds="True">
                            <Panel>
                              <!-- Commander art crop -->
                              <controls:ArtCropControl ScryfallId="{Binding CommanderScryfallId}"
                                                       Width="100" Height="74"
                                                       IsVisible="{Binding HasCommanderArt}" />
                              <!-- Grey placeholder for unlinked decks -->
                              <Border Width="100" Height="74" Background="#2D2D2D"
                                      IsVisible="{Binding !HasCommanderArt}">
                                <TextBlock Text="?" FontSize="36" FontWeight="Light" Opacity="0.25"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                              </Border>
                              <!-- Winner banner at bottom -->
                              <Border VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                      Background="#CC141414" Padding="6,4"
                                      IsVisible="{Binding IsWinner}">
                                <TextBlock Text="★  Winner" FontSize="11" Foreground="#FFD700"
                                           FontWeight="Bold" HorizontalAlignment="Center" />
                              </Border>
                              <!-- Position badge top-right for non-winners -->
                              <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                      Background="#AA000000" Padding="5,2" CornerRadius="0,6,0,5"
                                      IsVisible="{Binding !IsWinner}">
                                <TextBlock Text="{Binding FinishPosition, StringFormat='#{0}'}"
                                           FontSize="10" Foreground="White" FontWeight="SemiBold" />
                              </Border>
                            </Panel>
                          </Border>
                          <!-- Player label below art -->
                          <Border Background="{DynamicResource ThemeSurfaceVariantBrush}"
                                  CornerRadius="0,0,6,6" Padding="7,5">
                            <StackPanel Spacing="1">
                              <TextBlock Text="{Binding PlayerName}" FontSize="12" FontWeight="SemiBold"
                                         TextTrimming="CharacterEllipsis" />
                              <TextBlock Text="{Binding DeckDisplayName}" FontSize="10" Opacity="0.6"
                                         TextTrimming="CharacterEllipsis"
                                         IsVisible="{Binding DeckDisplayName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                          </Border>
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <!-- ── Info row ── -->
                  <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                    <!-- Result badge -->
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                            VerticalAlignment="Top" Margin="0,2,0,0"
                            Background="{Binding IWon, Converter={x:Static converters:BoolToWinColorConverter.Instance}}">
                      <TextBlock Text="{Binding ResultText}" FontWeight="Bold" FontSize="14"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Foreground="White" />
                    </Border>

                    <!-- Details -->
                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding PlayedAtLocal}" FontWeight="SemiBold" FontSize="13" />
                        <TextBlock Text="{Binding TurnEnded, StringFormat='Turn {0}'}"
                                   IsVisible="{Binding TurnEnded, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   Opacity="0.6" FontSize="12" VerticalAlignment="Center" />
                      </StackPanel>

                      <!-- Winner summary -->
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Winner:" Opacity="0.6" FontSize="11" />
                        <TextBlock Text="{Binding WinnerName}" FontSize="11" FontWeight="SemiBold" />
                      </StackPanel>

                      <!-- Player chips (all players, text only) -->
                      <ItemsControl ItemsSource="{Binding Players}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="models:GamePlayer">
                            <Border Margin="0,2,6,2" Padding="5,2" CornerRadius="3"
                                    Background="{DynamicResource ThemeSurfaceVariantBrush}">
                              <StackPanel Orientation="Horizontal" Spacing="3">
                                <TextBlock Text="★" FontSize="10" Foreground="#FFD700"
                                           IsVisible="{Binding IsWinner}"
                                           VerticalAlignment="Center" />
                                <TextBlock FontSize="11" VerticalAlignment="Center">
                                  <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} ({1})">
                                      <Binding Path="PlayerName" />
                                      <Binding Path="DeckDisplayName" />
                                    </MultiBinding>
                                  </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="{Binding FinishPosition, StringFormat='#{0}'}"
                                           FontSize="10" Opacity="0.6" VerticalAlignment="Center" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                      <!-- Notes -->
                      <TextBlock Text="{Binding Notes}" FontSize="11" Opacity="0.6"
                                 FontStyle="Italic" TextWrapping="Wrap"
                                 IsVisible="{Binding Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>

                    <!-- Edit / Delete -->
                    <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Top">
                      <Button Content="✎"
                              Command="{Binding $parent[UserControl].((vm:GamesViewModel)DataContext).EditGameCommand}"
                              CommandParameter="{Binding}"
                              Padding="6,4" FontSize="11"
                              ToolTip.Tip="Edit this game record" />
                      <Button Content="✕"
                              Command="{Binding $parent[UserControl].((vm:GamesViewModel)DataContext).DeleteGameCommand}"
                              CommandParameter="{Binding}"
                              Padding="6,4" FontSize="11"
                              ToolTip.Tip="Delete this game record" />
                    </StackPanel>
                  </Grid>

                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </DockPanel>

  </Grid>
</UserControl>
