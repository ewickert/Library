<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Library.ViewModels"
             xmlns:mtg="using:MtgJson.Models"
             x:Class="Library.Views.MtgJsonPaneView"
             x:DataType="vm:MtgJsonPaneViewModel">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ── Header / Search toolbar ─────────────────────────────────────── -->
    <Border Grid.Row="0" Padding="10,10,10,6">
      <StackPanel Spacing="6">

        <!-- Title row -->
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="Browse MTGJSON Decks" FontWeight="SemiBold" FontSize="13"
                     VerticalAlignment="Center" />
          <ProgressBar IsIndeterminate="True"
                       IsVisible="{Binding IsLoading}"
                       Width="60" Height="8" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Search box + button -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
          <TextBox Grid.Column="0"
                   Text="{Binding SearchText}"
                   Watermark="Search by name or set code…"
                   FontSize="12" />
          <Button Grid.Column="1"
                  Content="🔍 Search"
                  Command="{Binding SearchCommand}"
                  Padding="10,4" FontSize="12" />
        </Grid>

      </StackPanel>
    </Border>

    <!-- ── Results + detail split ──────────────────────────────────────── -->
    <Grid Grid.Row="1" RowDefinitions="*,Auto">

      <!-- Deck results list -->
      <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                    Margin="8,0,8,0">
        <StackPanel Spacing="0">

          <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.5"
                     Margin="4,8,4,0"
                     IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

          <ItemsControl ItemsSource="{Binding DeckResults}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:MtgJsonDeckViewModel">
                <Button Background="Transparent" Padding="0" Margin="0,0,0,2"
                        HorizontalAlignment="Stretch"
                        Command="{Binding $parent[UserControl].((vm:MtgJsonPaneViewModel)DataContext).SelectDeckResultCommand}"
                        CommandParameter="{Binding}">
                  <Border Padding="10,8" CornerRadius="6" HorizontalAlignment="Stretch">
                    <Border.Styles>
                      <Style Selector="Border">
                        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
                      </Style>
                    </Border.Styles>
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Meta}" FontSize="10" Opacity="0.65" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

        </StackPanel>
      </ScrollViewer>

      <!-- ── Selected deck detail ─────────────────────────────────────── -->
      <Border Grid.Row="1"
              IsVisible="{Binding SelectedDeckResult, Converter={x:Static ObjectConverters.IsNotNull}}"
              Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
              CornerRadius="8" Margin="8,8,8,0" Padding="10">

        <StackPanel Spacing="6">

          <!-- Loading spinner -->
          <StackPanel Orientation="Horizontal" Spacing="6"
                      IsVisible="{Binding IsLoadingDeck}">
            <ProgressBar IsIndeterminate="True" Width="80" Height="8" VerticalAlignment="Center" />
            <TextBlock Text="Loading deck…" FontSize="11" Opacity="0.6" VerticalAlignment="Center" />
          </StackPanel>

          <!-- Deck detail once loaded -->
          <StackPanel IsVisible="{Binding SelectedDeck, Converter={x:Static ObjectConverters.IsNotNull}}"
                      Spacing="6">

            <TextBlock Text="{Binding SelectedDeck.Name}" FontWeight="Bold" FontSize="13"
                       TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock FontSize="11" Opacity="0.7" Text="{Binding SelectedDeck.Type}" />
              <TextBlock FontSize="11" Opacity="0.5" Text="·" />
              <TextBlock FontSize="11" Opacity="0.7" Text="{Binding SelectedDeck.ReleaseDate}" />
            </StackPanel>

            <!-- Commander(s) -->
            <StackPanel IsVisible="{Binding SelectedDeck.Commander.Count}"
                        Spacing="2">
              <TextBlock Text="Commander" FontSize="11" FontWeight="SemiBold" Opacity="0.8" />
              <ItemsControl ItemsSource="{Binding SelectedDeck.Commander}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="mtg:DeckCard">
                    <TextBlock FontSize="11" Margin="0,1">
                      <Run Text="{Binding Name}" />
                    </TextBlock>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <!-- Mainboard preview -->
            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    CornerRadius="4" Padding="6,4" MaxHeight="160">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding SelectedDeck.MainBoard}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="mtg:DeckCard">
                      <TextBlock FontSize="11" Margin="0,1">
                        <Run Text="{Binding Count}" />
                        <Run Text="× " />
                        <Run Text="{Binding Name}" />
                      </TextBlock>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>

            <!-- Status text -->
            <TextBlock Text="{Binding StatusText}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                       IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="+ Import to Collection"
                      Command="{Binding ImportToCollectionCommand}"
                      IsEnabled="{Binding !IsImporting}"
                      Padding="10,5" FontSize="12" />
              <Button Content="⧉ Clone to Builder"
                      Command="{Binding CloneToDeckBuilderCommand}"
                      IsEnabled="{Binding !IsImporting}"
                      Padding="10,5" FontSize="12" />
            </StackPanel>

          </StackPanel>

        </StackPanel>
      </Border>

    </Grid>

    <!-- Bottom padding -->
    <Border Grid.Row="2" Height="8" />

  </Grid>

</UserControl>
