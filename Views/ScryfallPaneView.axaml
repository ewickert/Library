<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Library.ViewModels"
             xmlns:controls="using:Library.Views.Controls"
             x:Class="Library.Views.ScryfallPaneView"
             x:DataType="vm:DecksViewModel">

  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- Row 0: Pane header -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="10,8,10,6">
      <TextBlock Text="Scryfall" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" />
      <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsCollectionExternalSearching}"
                   Width="50" Height="6" VerticalAlignment="Center" />
      <Button Command="{Binding ToggleCollectionExternalViewCommand}" Padding="6,2"
              ToolTip.Tip="Toggle grid/list view" FontSize="11">
        <StackPanel Orientation="Horizontal" Spacing="3">
          <TextBlock Text="⊞" IsVisible="{Binding !IsCollectionExternalGridView}" FontSize="12" />
          <TextBlock Text="☰" IsVisible="{Binding IsCollectionExternalGridView}" FontSize="12" />
        </StackPanel>
      </Button>
      <Button x:Name="PopOutButton"
              Content="⤢" ToolTip.Tip="Pop out into floating window"
              Padding="6,2" FontSize="11"
              Click="OnPopOutClick" />
    </StackPanel>

    <!-- Row 1: Search box -->
    <TextBox Grid.Row="1" Text="{Binding ScryfallSearchText}"
             Watermark="Search Scryfall…" Margin="8,0,8,8" />

    <!-- Row 2: Results -->
    <Panel Grid.Row="2">

      <!-- List view -->
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    IsVisible="{Binding !IsCollectionExternalGridView}">
        <Panel>
          <ItemsControl x:Name="ScryfallResultsListView" ItemsSource="{Binding CollectionExternalResults}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ScryfallResultViewModel">
                <Border Padding="8,5" BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                  <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0" Spacing="1">
                      <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock FontSize="10" Opacity="0.7" TextTrimming="CharacterEllipsis">
                        <Run Text="{Binding SetCode}" /><Run Text=" · " /><Run Text="{Binding TypeLine}" />
                      </TextBlock>
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <controls:ManaSymbolsControl ManaCost="{Binding ManaCost}"
                            IsVisible="{Binding ManaCost, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <TextBlock Text="{Binding Rarity}" FontSize="10" Opacity="0.7" VerticalAlignment="Center" />
                      </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding ToggleShoppingListCommand}"
                            Padding="5,2" FontSize="10" VerticalAlignment="Center" Margin="3,0,0,0">
                      <Panel>
                        <TextBlock Text="♥" IsVisible="{Binding !IsOnShoppingList}" />
                        <TextBlock Text="✓" IsVisible="{Binding IsOnShoppingList}" Foreground="LightGreen" />
                      </Panel>
                    </Button>
                    <Button Grid.Column="2"
                            Content="+"
                            ToolTip.Tip="Add to deck"
                            Command="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).AddScryfallCardToDeckCommand}"
                            CommandParameter="{Binding}"
                            Padding="6,2" FontSize="13" FontWeight="Bold"
                            VerticalAlignment="Center" Margin="3,0,0,0" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="Type to search Scryfall…"
                     IsVisible="{Binding CollectionExternalResults.Count, Converter={x:Static ObjectConverters.IsNull}}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" Margin="8" />
        </Panel>
      </ScrollViewer>

      <!-- Grid view -->
      <ScrollViewer x:Name="ScryfallGridScrollViewer" VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    IsVisible="{Binding IsCollectionExternalGridView}">
        <Panel>
          <ItemsControl x:Name="ScryfallResultsGridView" ItemsSource="{Binding CollectionExternalResults}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ScryfallResultViewModel">
                <Border Width="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).CollectionTileWidth}"
                        Height="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).CollectionTileHeight}"
                        CornerRadius="6" ClipToBounds="True" Margin="4"
                        ToolTip.ShowDelay="200"
                        Background="{DynamicResource ThemeSurfaceVariantBrush}">
                  <ToolTip.Tip>
                    <Border Background="#1A1A2A" CornerRadius="8" Padding="6">
                      <Panel>
                        <Image Source="{Binding Image}" MaxWidth="280" MaxHeight="392" Stretch="Uniform"
                               IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <StackPanel Spacing="4" Margin="4"
                                    IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}">
                          <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" FontWeight="Bold"
                                     TextWrapping="Wrap" MaxWidth="268" />
                          <TextBlock Text="{Binding TypeLine}" Foreground="#CCCCCC" FontSize="11"
                                     TextWrapping="Wrap" MaxWidth="268" />
                          <controls:ManaSymbolsControl ManaCost="{Binding ManaCost}" />
                        </StackPanel>
                      </Panel>
                    </Border>
                  </ToolTip.Tip>
                  <Panel>
                    <Image Source="{Binding Image}" Stretch="UniformToFill"
                           IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsVisible="{Binding IsLoading}" Spacing="4">
                      <ProgressBar IsIndeterminate="True" Width="60" />
                      <TextBlock Text="{Binding Name}" FontSize="9" TextWrapping="Wrap"
                                 HorizontalAlignment="Center" TextAlignment="Center" Opacity="0.6" MaxWidth="108" />
                    </StackPanel>
                    <Panel IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}">
                      <Panel IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}">
                        <StackPanel Spacing="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                          <TextBlock Text="🃏" FontSize="22" HorizontalAlignment="Center" />
                          <TextBlock Text="{Binding Name}" FontSize="9" TextWrapping="Wrap"
                                     MaxWidth="108" HorizontalAlignment="Center" TextAlignment="Center" />
                        </StackPanel>
                      </Panel>
                    </Panel>
                    <!-- Add to deck button -->
                    <Button Command="{Binding $parent[UserControl].((vm:DecksViewModel)DataContext).AddScryfallCardToDeckCommand}"
                            CommandParameter="{Binding}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="3" Padding="5,2" FontSize="12" FontWeight="Bold"
                            CornerRadius="4" ToolTip.Tip="Add to deck">
                      <Button.Styles>
                        <Style Selector="Button">
                          <Setter Property="Background" Value="#CC1A3A6C" />
                          <Setter Property="Foreground" Value="White" />
                        </Style>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                          <Setter Property="Background" Value="#EE2244AA" />
                        </Style>
                      </Button.Styles>
                      <TextBlock Text="+" />
                    </Button>
                    <Border Background="#AA000000" CornerRadius="0,0,6,6"
                            VerticalAlignment="Bottom" Padding="4,2">
                      <TextBlock Text="{Binding Name}" FontSize="9" Foreground="White"
                                 TextTrimming="CharacterEllipsis" />
                    </Border>
                  </Panel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Panel>
      </ScrollViewer>

    </Panel>

    <!-- Row 3: Load More -->
    <Button Grid.Row="3"
            Content="Load More"
            Command="{Binding LoadMoreExternalResultsCommand}"
            IsVisible="{Binding HasMoreExternalResults}"
            HorizontalAlignment="Stretch"
            Margin="8,4,8,8" Padding="6,4" FontSize="11" />

  </Grid>
</UserControl>
