<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Library.ViewModels"
             xmlns:controls="using:Library.Views.Controls"
             x:Class="Library.Views.ShoppingView"
             x:DataType="vm:ShoppingViewModel">

  <Grid RowDefinitions="Auto,*">

    <!-- Toolbar -->
        <ScrollViewer Grid.Row="0"
          HorizontalScrollBarVisibility="Auto"
          VerticalScrollBarVisibility="Disabled"
          Margin="8,8,8,4">
          <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="🛒 Shopping List" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
      <TextBox Text="{Binding SearchText}" Watermark="Filter…" Width="180" />
      <ComboBox ItemsSource="{Binding DeckFilterOptions}"
          SelectedItem="{Binding SelectedDeckFilter}"
          Width="170"
          ToolTip.Tip="Filter by deck"
          VerticalAlignment="Center" />
      <Button Content="⬆ Export for Card Kingdom" Click="OnExportCkClick"
        ToolTip.Tip="Copy the current list to clipboard in Card Kingdom deck builder format (1 Card Name per line)"
        VerticalAlignment="Center" />
      <TextBlock Text="✓ Copied!" IsVisible="{Binding ExportCopied}"
           Foreground="LightGreen" FontSize="12" VerticalAlignment="Center" />
      <Button Content="⬆ Export for TCGPlayer" Click="OnExportTcgClick"
        ToolTip.Tip="Copy the current list to clipboard in TCGPlayer Mass Entry format (1 Name [SET] # per line)"
        VerticalAlignment="Center" />
      <TextBlock Text="✓ Copied!" IsVisible="{Binding TcgExportCopied}"
           Foreground="LightGreen" FontSize="12" VerticalAlignment="Center" />
          </StackPanel>
        </ScrollViewer>

    <!-- Items list -->
    <ScrollViewer Grid.Row="1">
      <ItemsControl ItemsSource="{Binding Items}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ShoppingItemViewModel">
            <Border Margin="8,4" Padding="8" CornerRadius="6"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    BoxShadow="0 1 4 0 #22000000"
                    ToolTip.ShowDelay="300">
              <ToolTip.Tip>
                <Border Background="#1A1A2A" CornerRadius="8" Padding="6">
                  <Panel>
                    <Image Source="{Binding Image}" MaxWidth="280" MaxHeight="392" Stretch="Uniform"
                           IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <StackPanel Spacing="4" Margin="4"
                                IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}">
                      <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" FontWeight="Bold"
                                 TextWrapping="Wrap" MaxWidth="268" />
                      <TextBlock Text="{Binding TypeLine}" Foreground="#CCCCCC" FontSize="11"
                                 TextWrapping="Wrap" MaxWidth="268" />
                      <controls:ManaSymbolsControl ManaCost="{Binding ManaCost}" />
                    </StackPanel>
                  </Panel>
                </Border>
              </ToolTip.Tip>
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="8">

                <!-- Card thumbnail -->
                <Border Grid.Column="0" Width="60" Height="84" CornerRadius="4"
                        ClipToBounds="True" Margin="0,0,12,0">
                  <Panel>
                    <TextBlock IsVisible="{Binding IsLoadingImage}"
                               Text="…" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemBaseMediumColor}" />
                    <Image Source="{Binding Image}" Stretch="UniformToFill"
                           IsVisible="{Binding !IsLoadingImage}" />
                  </Panel>
                </Border>

                <!-- Card info -->
                <StackPanel Grid.Column="1" Grid.Row="0" Spacing="2" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                  <TextBlock Text="{Binding TypeLine}" FontSize="11"
                             Foreground="{DynamicResource SystemBaseMediumColor}" />
                  <TextBlock FontSize="11" Foreground="{DynamicResource SystemBaseMediumColor}">
                    <Run Text="{Binding SetCode}" /><Run Text=" · " /><Run Text="{Binding SetName}" />
                  </TextBlock>
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <controls:ManaSymbolsControl ManaCost="{Binding ManaCost}"
                        IsVisible="{Binding ManaCost, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    <TextBlock Text="{Binding Rarity}" FontSize="11"
                               Foreground="{DynamicResource SystemBaseMediumColor}" VerticalAlignment="Center" />
                  </StackPanel>
                  <TextBlock Text="{Binding DeckNamesLabel}" FontSize="11"
                             Foreground="#8899CCFF" FontStyle="Italic" />
                  <TextBlock Text="{Binding CurrentPriceLabel}" FontSize="12" FontWeight="SemiBold"
                             Foreground="#66DD88"
                             IsVisible="{Binding CurrentPriceLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                      Orientation="Horizontal" Spacing="8"
                      HorizontalAlignment="Right">
                  <Button Content="Add to Deck"
                          Command="{Binding AddToDeckCommand}"
                          ToolTip.Tip="Add to currently selected deck"
                          Padding="8,4" />
                  <Button Content="Remove"
                          Command="{Binding RemoveCommand}"
                          Foreground="Red"
                          Padding="8,4" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </Grid>

</UserControl>
